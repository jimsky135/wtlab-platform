---
// Registry-driven placeholder for planned workspaces. Shared by both
// locale route files.
import StatusTag from '../components/StatusTag.astro';
import PlatformShell from '../layouts/PlatformShell.astro';
import { getDictionary, localizePath, type Locale } from '../i18n';
import type { WorkspaceEntry } from '../platform/catalog';

interface Props {
	workspace: WorkspaceEntry;
	locale?: Locale;
}
const { workspace, locale = 'en' } = Astro.props;
const t = getDictionary(locale);
const text = t.workspaces[workspace.id] ?? workspace;
---

<PlatformShell title={`${text.displayName} · ${t.seo.titleSuffix}`} section="workspaces" locale={locale}>
	<p class="kicker">{t.workspacePlaceholder.kickerPrefix} · {workspace.layer}</p>
	<h1>{text.displayName}</h1>
	<StatusTag
		status={workspace.status}
		implementationState={workspace.implementationState}
		enabled={workspace.enabled}
		locale={locale}
	/>

	<dl class="facts">
		<dt>{t.workspacePlaceholder.purposeLabel}</dt>
		<dd>{text.description}</dd>
		<dt>{t.workspacePlaceholder.coreQuestionLabel}</dt>
		<dd>{text.coreQuestion}</dd>
		{workspace.prototypeRefs.length > 0 && (
			<>
				<dt>{t.workspacePlaceholder.relatedPrototypesLabel}</dt>
				<dd>{workspace.prototypeRefs.join(', ')} {t.instrumentPlaceholder.relatedPrototypesNote}</dd>
			</>
		)}
	</dl>

	<p class="notice">{t.workspacePlaceholder.notice}</p>

	<p class="back"><a href={localizePath(locale, '/workspaces')}>{t.workspacePlaceholder.backLink}</a></p>
</PlatformShell>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
	}

	.facts {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-xs) var(--space-md);
		margin: var(--space-lg) 0 0;
		border-top: var(--border-hairline);
		padding-top: var(--space-lg);
	}

	.facts dt {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.facts dd {
		margin: 0;
		color: var(--color-text-primary);
	}

	.notice {
		margin: var(--space-lg) 0 0;
		border: var(--border-hairline);
		padding: var(--space-md);
		color: var(--color-text-secondary);
	}

	.back {
		margin: var(--space-lg) 0 0;
	}

	.back a {
		color: var(--color-accent);
	}
</style>
