---
// Continuity Center — honest placeholder for future save/export/
// re-import/AI-handoff capabilities. Nothing here pretends to work.
import PlatformShell from '../layouts/PlatformShell.astro';
import { getDictionary, type Locale } from '../i18n';
import { continuityActions } from '../platform/workspaces';

interface Props {
	locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = getDictionary(locale);
---

<PlatformShell title={`${t.continuityPage.heading} · ${t.seo.titleSuffix}`} section="continuity" locale={locale}>
	<p class="kicker">{t.continuityPage.kicker}</p>
	<h1>{t.continuityPage.heading}</h1>
	<p class="lede">{t.continuityPage.lede}</p>

	<ul class="actions">
		{continuityActions.map((action) => {
			// continuityActions.id is typed as the broader platform Capability
			// union; these five ids are the only ones the real data uses.
			const text = t.common.continuity.actions[action.id as keyof typeof t.common.continuity.actions];
			return (
				<li>
					<div class="action-head">
						<h2>{text.label}</h2>
						<span class="planned-tag">{t.common.continuity.planned}</span>
					</div>
					<p>{text.description}</p>
				</li>
			);
		})}
	</ul>

	<p class="boundary-note">{t.continuityPage.boundaryNote}</p>
</PlatformShell>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
	}

	.lede {
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-xl);
	}

	.actions {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.actions li {
		border: var(--border-hairline);
		padding: var(--space-md);
	}

	.action-head {
		display: flex;
		align-items: baseline;
		gap: var(--space-sm);
	}

	h2 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: 1.3rem;
		margin: 0;
	}

	.planned-tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		border: var(--border-hairline);
		padding: 2px 8px;
	}

	.actions p {
		color: var(--color-text-secondary);
		margin: var(--space-xs) 0 0;
	}

	.boundary-note {
		margin: var(--space-xl) 0 0;
		color: var(--color-text-tertiary);
		border-top: var(--border-hairline);
		padding-top: var(--space-md);
	}
</style>
