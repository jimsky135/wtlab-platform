---
// Data Intake Workspace — engineering demonstration of the Shared Data
// Intake Foundation (parse → normalize → validate → preview → confirm).
// This is a platform workspace/foundation demo, not a customer-facing
// instrument. All processing is local to the browser. One shared view
// across both locales; only the demo schema's label/description and the
// surrounding UI copy vary — intake logic itself is untouched.
import StatusTag from '../components/StatusTag.astro';
import PlatformShell from '../layouts/PlatformShell.astro';
import { getDictionary, type Locale } from '../i18n';
import { findById } from '../platform/catalog';
import { workspaces } from '../platform/workspaces';
import { getDemoIntakeSchema } from './_data-intake-demo-schema';

interface Props {
	locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = getDictionary(locale);
const di = t.dataIntake;
const entry = findById(workspaces, 'data-intake');
const demoIntakeSchema = getDemoIntakeSchema(locale);
---

<PlatformShell title={`${di.heading} · ${t.seo.titleSuffix}`} section="workspaces" locale={locale}>
	<p class="kicker">{di.kicker}</p>
	<h1>{di.heading}</h1>
	{entry && (
		<StatusTag status={entry.status} implementationState={entry.implementationState} enabled={entry.enabled} locale={locale} />
	)}
	<p class="lede">{di.lede}</p>

	<p class="status-line">
		{di.statusLine} <span id="intake-status" aria-live="polite">{di.statusLabels.empty}</span>
	</p>

	<section aria-labelledby="manual-heading">
		<h2 id="manual-heading">{di.manualHeading}</h2>
		<p class="section-note">{di.schemaLabel} {demoIntakeSchema.title}</p>
		<form id="manual-form">
			{demoIntakeSchema.fields.map((field) => (
				<div class="field">
					<label for={`mf-${field.id}`}>
						{field.label}
						{field.required ? <span class="required-marker"> {di.requiredMarker}</span> : <span class="optional-marker"> {di.optionalMarker}</span>}
					</label>
					{field.description && <p class="field-description">{field.description}</p>}
					<input id={`mf-${field.id}`} name={field.id} type="text" inputmode={field.type === 'number' ? 'decimal' : undefined} />
				</div>
			))}
			<button type="submit">{di.reviewEntry}</button>
		</form>
	</section>

	<section aria-labelledby="csv-heading">
		<h2 id="csv-heading">{di.csvHeading}</h2>
		<p class="section-note">{di.csvNote}</p>
		<div class="field">
			<label for="csv-file">{di.fileLabel}</label>
			<input id="csv-file" type="file" accept=".csv,text/csv" />
		</div>
		<div id="csv-issues" class="issue-box" aria-live="polite" hidden></div>

		<div id="mapping-panel" hidden>
			<h3>{di.mappingHeading}</h3>
			<p class="section-note">{di.mappingNote}</p>
			<div id="mapping-rows" class="mapping-rows"></div>
			<div id="mapping-issues" class="issue-box" aria-live="polite" hidden></div>
			<button type="button" id="apply-mapping">{di.applyMapping}</button>
		</div>
	</section>

	<section id="preview-panel" aria-labelledby="preview-heading" hidden>
		<h2 id="preview-heading">{di.previewHeading}</h2>
		<p class="section-note">{di.previewNote}</p>
		<div id="preview-table" class="preview-table" tabindex="0"></div>

		<div id="issue-groups">
			<div id="group-errors" hidden>
				<h3>{di.groupErrors} <span class="count" id="count-errors"></span></h3>
				<p class="group-note">{di.groupErrorsNote}</p>
				<ul id="list-errors"></ul>
			</div>
			<div id="group-warnings" hidden>
				<h3>{di.groupWarnings} <span class="count" id="count-warnings"></span></h3>
				<p class="group-note">{di.groupWarningsNote}</p>
				<ul id="list-warnings"></ul>
			</div>
			<div id="group-notes" hidden>
				<h3>{di.groupNotes} <span class="count" id="count-notes"></span></h3>
				<p class="group-note">{di.groupNotesNote}</p>
				<ul id="list-notes"></ul>
			</div>
		</div>

		<div class="confirm-row">
			<button type="button" id="confirm-btn" disabled>{di.confirmButton}</button>
			<span id="confirm-reason" class="confirm-reason"></span>
		</div>
	</section>

	<section id="confirmed-panel" aria-labelledby="confirmed-heading" hidden>
		<h2 id="confirmed-heading">{di.confirmedHeading}</h2>
		<p class="section-note">{di.confirmedNote}</p>
		<pre id="confirmed-output"></pre>
	</section>
</PlatformShell>

<script define:vars={{ locale }}>
	window.__WTLAB_LOCALE__ = locale;
</script>

<script>
	import { canConfirm, confirmIntake } from '../platform/intake/confirm.ts';
	import { parseCsv, type CsvParseResult } from '../platform/intake/csv.ts';
	import { applyMapping, suggestMapping, validateMapping, type ColumnMapping } from '../platform/intake/mapping.ts';
	import type { IntakeIssue, IntakeValidationResult, RawIntakeRecord } from '../platform/intake/types.ts';
	import { validateRecords } from '../platform/intake/validate.ts';
	import { getDictionary, resolveMessage, type Locale } from '../i18n/index.ts';
	import { getDemoIntakeSchema } from './_data-intake-demo-schema.ts';

	const locale = ((window as unknown as { __WTLAB_LOCALE__?: Locale }).__WTLAB_LOCALE__ ?? 'en') as Locale;
	const di = getDictionary(locale).dataIntake;
	const demoIntakeSchema = getDemoIntakeSchema(locale);
	// This demo schema is already generated per-locale (see _data-intake-demo-schema.ts),
	// so field.label doubles as the localized field label — no separate map needed.
	const fieldLabels = Object.fromEntries(demoIntakeSchema.fields.map((field) => [field.id, field.label]));

	function localizedIssueMessage(issue: IntakeIssue): string {
		if (!issue.code) return issue.message;
		const rawField = typeof issue.params?.field === 'string' ? issue.params.field : issue.field;
		const params = { ...issue.params, ...(rawField !== undefined ? { field: fieldLabels[rawField] ?? rawField } : {}) };
		return resolveMessage(locale, issue.code, params);
	}

	const statusEl = document.getElementById('intake-status');
	const manualForm = document.querySelector<HTMLFormElement>('#manual-form');
	const csvFileInput = document.querySelector<HTMLInputElement>('#csv-file');
	const csvIssuesEl = document.getElementById('csv-issues');
	const mappingPanel = document.getElementById('mapping-panel');
	const mappingRows = document.getElementById('mapping-rows');
	const mappingIssuesEl = document.getElementById('mapping-issues');
	const applyMappingBtn = document.querySelector<HTMLButtonElement>('#apply-mapping');
	const previewPanel = document.getElementById('preview-panel');
	const previewTable = document.getElementById('preview-table');
	const confirmBtn = document.querySelector<HTMLButtonElement>('#confirm-btn');
	const confirmReason = document.getElementById('confirm-reason');
	const confirmedPanel = document.getElementById('confirmed-panel');
	const confirmedOutput = document.getElementById('confirmed-output');

	let currentParse: CsvParseResult | null = null;
	let currentResult: IntakeValidationResult | null = null;

	function setStatus(status: keyof typeof di.statusLabels) {
		if (statusEl) statusEl.textContent = di.statusLabels[status] ?? String(status);
	}

	function renderIssueBox(el: HTMLElement | null, issues: IntakeIssue[]) {
		if (!el) return;
		el.innerHTML = '';
		if (issues.length === 0) {
			el.hidden = true;
			return;
		}
		const list = document.createElement('ul');
		for (const issue of issues) {
			const item = document.createElement('li');
			item.textContent = `${issue.severity.toUpperCase()}: ${localizedIssueMessage(issue)}`;
			list.appendChild(item);
		}
		el.appendChild(list);
		el.hidden = false;
	}

	function issueText(issue: IntakeIssue): string {
		const location = issue.row !== undefined ? `${di.rowPrefix} ${issue.row + 1}` : null;
		const field = issue.field ? `“${issue.field}”` : null;
		const prefix = [location, field].filter(Boolean).join(' · ');
		const text = localizedIssueMessage(issue);
		return prefix ? `${prefix}: ${text}` : text;
	}

	function renderPreview(result: IntakeValidationResult) {
		currentResult = result;
		if (!previewPanel || !previewTable) return;

		// Table: one row per record, one column per schema field (+ unknown).
		previewTable.innerHTML = '';
		const table = document.createElement('table');
		const thead = document.createElement('thead');
		const headRow = document.createElement('tr');
		const unknownKeys = [...new Set(result.records.flatMap((record) => Object.keys(record.unknown)))];
		const headers = ['#', ...demoIntakeSchema.fields.map((field) => field.label), ...unknownKeys.map((key) => `${key} ${di.unknownSuffix}`)];
		for (const header of headers) {
			const th = document.createElement('th');
			th.textContent = header;
			headRow.appendChild(th);
		}
		thead.appendChild(headRow);
		table.appendChild(thead);

		const tbody = document.createElement('tbody');
		result.records.forEach((record, index) => {
			const tr = document.createElement('tr');
			const rowHasError = result.issues.some((issue) => issue.row === index && issue.severity === 'error');
			const rowHasWarning = result.issues.some((issue) => issue.row === index && issue.severity === 'warning');
			if (rowHasError) tr.classList.add('row-error');
			else if (rowHasWarning) tr.classList.add('row-warning');

			const num = document.createElement('td');
			num.textContent = String(index + 1) + (rowHasError ? ` ⚠ ${di.errorSuffix}` : rowHasWarning ? ` ⚠ ${di.warningSuffix}` : '');
			tr.appendChild(num);

			for (const field of demoIntakeSchema.fields) {
				const td = document.createElement('td');
				const normalized = record.fields[field.id];
				const interpreted = normalized.value === undefined ? '—' : String(normalized.value);
				td.textContent = interpreted;
				if (normalized.changed) {
					td.classList.add('cell-changed');
					td.title = `${di.rawValueTooltip}: "${normalized.raw}"`;
					const raw = document.createElement('span');
					raw.className = 'raw-note';
					raw.textContent = ` (${di.rawNote}: "${normalized.raw}")`;
					td.appendChild(raw);
				}
				tr.appendChild(td);
			}

			for (const key of unknownKeys) {
				const td = document.createElement('td');
				td.classList.add('cell-unknown');
				td.textContent = record.unknown[key] ?? '';
				tr.appendChild(td);
			}

			tbody.appendChild(tr);
		});
		table.appendChild(tbody);
		previewTable.appendChild(table);

		// Issue groups.
		const groups: Array<[string, string, string, (issue: IntakeIssue) => boolean]> = [
			['group-errors', 'list-errors', 'count-errors', (issue) => issue.severity === 'error'],
			['group-warnings', 'list-warnings', 'count-warnings', (issue) => issue.severity === 'warning'],
			['group-notes', 'list-notes', 'count-notes', (issue) => issue.severity === 'info'],
		];
		for (const [groupId, listId, countId, match] of groups) {
			const group = document.getElementById(groupId);
			const list = document.getElementById(listId);
			const count = document.getElementById(countId);
			if (!group || !list || !count) continue;
			const matched = result.issues.filter(match);
			list.innerHTML = '';
			for (const issue of matched) {
				const item = document.createElement('li');
				item.textContent = issueText(issue);
				list.appendChild(item);
			}
			count.textContent = `(${matched.length})`;
			group.hidden = matched.length === 0;
		}

		const confirmable = canConfirm(result);
		if (confirmBtn) confirmBtn.disabled = !confirmable;
		if (confirmReason) {
			confirmReason.textContent = confirmable
				? result.warningCount > 0
					? di.confirmReasonWarnings
					: di.confirmReasonOk
				: di.confirmReasonBlocked;
		}

		if (confirmedPanel) confirmedPanel.hidden = true;
		previewPanel.hidden = false;
		setStatus(confirmable ? 'ready' : 'validation-failed');
		previewPanel.scrollIntoView({ block: 'nearest' });
	}

	// --- Manual entry ---
	if (manualForm) {
		manualForm.addEventListener('input', () => setStatus('editing'));
		manualForm.addEventListener('submit', (event) => {
			event.preventDefault();
			const record: RawIntakeRecord = { values: {}, unknown: {} };
			for (const field of demoIntakeSchema.fields) {
				const input = manualForm.elements.namedItem(field.id);
				record.values[field.id] = input instanceof HTMLInputElement ? input.value : '';
			}
			renderPreview(validateRecords([record], demoIntakeSchema));
		});
	}

	// --- CSV import ---
	function renderMappingUI(parse: CsvParseResult) {
		if (!mappingPanel || !mappingRows) return;
		const suggested = suggestMapping(parse.headers, demoIntakeSchema);
		mappingRows.innerHTML = '';
		parse.headers.forEach((header, index) => {
			const row = document.createElement('div');
			row.className = 'mapping-row';
			const label = document.createElement('label');
			const selectId = `map-${index}`;
			label.htmlFor = selectId;
			label.textContent = header;
			const select = document.createElement('select');
			select.id = selectId;
			select.dataset.header = header;
			const noneOption = document.createElement('option');
			noneOption.value = '';
			noneOption.textContent = di.keepAsUnknown;
			select.appendChild(noneOption);
			for (const field of demoIntakeSchema.fields) {
				const option = document.createElement('option');
				option.value = field.id;
				option.textContent = field.label;
				if (suggested[header] === field.id) option.selected = true;
				select.appendChild(option);
			}
			row.append(label, select);
			mappingRows.appendChild(row);
		});
		mappingPanel.hidden = false;
		setStatus('mapping');
	}

	function currentMapping(): ColumnMapping {
		const mapping: ColumnMapping = {};
		if (!mappingRows) return mapping;
		for (const select of mappingRows.querySelectorAll<HTMLSelectElement>('select')) {
			const header = select.dataset.header ?? '';
			mapping[header] = select.value === '' ? null : select.value;
		}
		return mapping;
	}

	if (csvFileInput) {
		csvFileInput.addEventListener('change', async () => {
			const file = csvFileInput.files?.[0];
			if (!file) return;
			setStatus('parsing');
			if (previewPanel) previewPanel.hidden = true;
			if (confirmedPanel) confirmedPanel.hidden = true;
			const text = await file.text();
			currentParse = parseCsv(text, file.name);
			renderIssueBox(csvIssuesEl, currentParse.issues);
			if (currentParse.ok) {
				renderMappingUI(currentParse);
			} else {
				if (mappingPanel) mappingPanel.hidden = true;
				setStatus('validation-failed');
			}
		});
	}

	if (applyMappingBtn) {
		applyMappingBtn.addEventListener('click', () => {
			if (!currentParse) return;
			const mapping = currentMapping();
			const mappingIssues = validateMapping(mapping, demoIntakeSchema);
			renderIssueBox(mappingIssuesEl, mappingIssues);
			if (mappingIssues.some((issue) => issue.severity === 'error')) {
				setStatus('validation-failed');
				return;
			}
			const rawRecords = applyMapping(currentParse, mapping);
			renderPreview(validateRecords(rawRecords, demoIntakeSchema));
		});
	}

	// --- Confirmation ---
	if (confirmBtn) {
		confirmBtn.addEventListener('click', () => {
			if (!currentResult) return;
			const outcome = confirmIntake(demoIntakeSchema, currentResult);
			if (!outcome.confirmed) {
				if (confirmReason) confirmReason.textContent = resolveMessage(locale, outcome.code, outcome.params);
				return;
			}
			if (confirmedOutput) confirmedOutput.textContent = JSON.stringify(outcome.data, null, 2);
			if (confirmedPanel) {
				confirmedPanel.hidden = false;
				confirmedPanel.scrollIntoView({ block: 'nearest' });
			}
			setStatus('confirmed');
		});
	}
</script>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
	}

	.lede {
		color: var(--color-text-secondary);
		margin: var(--space-sm) 0 var(--space-md);
	}

	.status-line {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
		border: var(--border-hairline);
		display: inline-block;
		padding: var(--space-xs) var(--space-sm);
		margin: 0 0 var(--space-md);
	}

	.status-line span {
		color: var(--color-accent);
	}

	section {
		border-top: var(--border-hairline);
		margin-top: var(--space-lg);
		padding-top: var(--space-lg);
	}

	h2 {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-sm);
	}

	h3 {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
		margin: var(--space-md) 0 var(--space-xs);
	}

	.section-note {
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-md);
		font-size: 0.95rem;
	}

	.group-note {
		color: var(--color-text-muted);
		font-size: 0.85rem;
		margin: 0 0 var(--space-xs);
	}

	form,
	.field {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	form {
		gap: var(--space-md);
	}

	label {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.required-marker {
		color: var(--color-accent);
		text-transform: none;
		letter-spacing: normal;
	}

	.optional-marker {
		color: var(--color-text-muted);
		text-transform: none;
		letter-spacing: normal;
	}

	.field-description {
		color: var(--color-text-muted);
		font-size: 0.85rem;
		margin: 0;
	}

	input,
	select {
		background: var(--color-bg-raised);
		border: var(--border-hairline);
		color: var(--color-text-primary);
		font-family: var(--font-body);
		font-size: 1rem;
		padding: var(--space-sm);
	}

	input[type='file'] {
		padding: var(--space-xs);
	}

	button {
		align-self: flex-start;
		background: var(--color-accent);
		color: var(--color-bg);
		border: none;
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		padding: var(--space-sm) var(--space-lg);
		cursor: pointer;
	}

	button:disabled {
		background: var(--color-bg-raised);
		color: var(--color-text-muted);
		border: var(--border-hairline);
		cursor: not-allowed;
	}

	.issue-box {
		border: var(--border-hairline);
		padding: var(--space-sm) var(--space-md);
		margin: var(--space-sm) 0;
		color: var(--color-text-primary);
	}

	.issue-box ul,
	#issue-groups ul {
		margin: 0;
		padding-left: 1.2em;
	}

	.mapping-rows {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
		margin-bottom: var(--space-md);
	}

	.mapping-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-sm);
	}

	.mapping-row label {
		min-width: 160px;
	}

	.preview-table {
		overflow-x: auto;
		border: var(--border-hairline);
	}

	.preview-table table {
		border-collapse: collapse;
		width: 100%;
	}

	.preview-table th,
	.preview-table td {
		border-bottom: var(--border-hairline);
		padding: var(--space-xs) var(--space-sm);
		text-align: left;
		font-size: 0.95rem;
		white-space: nowrap;
	}

	.preview-table th {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.row-error td:first-child {
		color: var(--color-accent-strong);
	}

	.row-warning td:first-child {
		color: var(--color-accent);
	}

	.cell-changed {
		border-left: 2px solid var(--color-accent);
	}

	.raw-note {
		color: var(--color-text-muted);
		font-size: 0.8rem;
	}

	.cell-unknown {
		color: var(--color-text-muted);
	}

	.confirm-row {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-md);
		margin-top: var(--space-md);
	}

	.confirm-reason {
		color: var(--color-text-secondary);
		font-size: 0.9rem;
	}

	#confirmed-output {
		background: var(--color-bg-inset);
		border: var(--border-hairline);
		padding: var(--space-md);
		overflow-x: auto;
		color: var(--color-text-primary);
		font-size: 0.85rem;
	}
</style>
