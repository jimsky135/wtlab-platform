---
// About / Architecture — placeholder describing the platform boundaries.
import PlatformShell from '../layouts/PlatformShell.astro';
import { getDictionary, type Locale } from '../i18n';

interface Props {
	locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = getDictionary(locale);
---

<PlatformShell title={`${t.about.heading} · ${t.seo.titleSuffix}`} section="about" locale={locale}>
	<p class="kicker">{t.about.kicker}</p>
	<h1>{t.about.heading}</h1>
	<p class="lede">{t.about.lede}</p>

	<dl class="boundaries">
		{t.about.boundaries.map((entry) => (
			<>
				<dt>{entry.term}</dt>
				<dd>{entry.definition}</dd>
			</>
		))}
	</dl>

	<p class="note">{t.about.note}</p>
</PlatformShell>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
	}

	.lede {
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-xl);
	}

	.boundaries {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-xs) var(--space-md);
		margin: 0;
		border-top: var(--border-hairline);
		padding-top: var(--space-lg);
	}

	.boundaries dt {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.boundaries dd {
		margin: 0;
	}

	.note {
		margin: var(--space-xl) 0 0;
		color: var(--color-text-secondary);
	}
</style>
