---
// Supplier Dependency & Qualification Radar — sixth production instrument
// (Sprint 009), one shared implementation across both locales. Models
// Supplier × Material relationships rather than one opaque per-supplier
// score: Supplier Dependency, Qualification Dependency, and Switching
// Readiness stay visible as separate dimensions (see docs/engineering.md).
// `reasonCodes` are stable machine codes — never translated, same
// convention as every prior instrument. `primaryWarningCode` and each
// `recommendedActionCodes` entry resolve through the current locale via
// resolveMessage(), same as Buffer Drift Monitor / Dead Stock Scanner.
import '../../shared/instrument.css';
import CapabilityPanel from '../../components/CapabilityPanel.astro';
import InstrumentHeader from '../../components/InstrumentHeader.astro';
import ModeSwitcher from '../../components/ModeSwitcher.astro';
import QuickForm from '../../components/QuickForm.astro';
import PlatformShell from '../../layouts/PlatformShell.astro';
import { getDictionary, localizePath, type Locale } from '../../i18n';
import { findById } from '../../platform/catalog';
import { instruments } from '../../platform/instruments';
import type { QuickFormFieldConfig } from '../../platform/quick-form';
import { platformRegistry } from '../../platform/registry';
import { supplierDependencyAdvancedContract } from '../../tools/supplier-dependency-radar/modes/advanced/contract';
import { supplierDependencyQuickContract } from '../../tools/supplier-dependency-radar/modes/quick/contract';

interface Props {
	locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = getDictionary(locale);
const rt = t.results.supplierDependencyRadar;

const TOOL_ID = 'supplier-dependency-radar';
const available = platformRegistry.isAvailable(TOOL_ID);
const entry = findById(instruments, TOOL_ID);
const modes = [supplierDependencyQuickContract, supplierDependencyAdvancedContract];

const quickFields: QuickFormFieldConfig[] = [
	{ id: 'supplierName', numeric: false, requiredOnForm: true },
	{ id: 'materialCount', numeric: true, requiredOnForm: true },
	{ id: 'criticalMaterialCount', numeric: true, requiredOnForm: true },
	{ id: 'supplierSharePercent', numeric: true, requiredOnForm: true },
	{ id: 'singleSourceMaterialCount', numeric: true, requiredOnForm: true },
	{ id: 'qualifiedSingleSourceMaterialCount', numeric: true, requiredOnForm: true },
	{ id: 'alternativeSupplierAvailable', numeric: false, requiredOnForm: false, placeholder: 'true / false' },
	{ id: 'qualifiedAlternativeAvailable', numeric: false, requiredOnForm: false, placeholder: 'true / false' },
	{ id: 'qualificationRequired', numeric: false, requiredOnForm: false, placeholder: 'true / false' },
	{ id: 'qualificationLeadTimeMonths', numeric: true, requiredOnForm: false },
	{ id: 'customerApprovalRequired', numeric: false, requiredOnForm: false, placeholder: 'true / false' },
	{ id: 'trialProductionRequired', numeric: false, requiredOnForm: false, placeholder: 'true / false' },
	{ id: 'averageLeadTimeDays', numeric: true, requiredOnForm: false },
	{ id: 'averageDelayDays', numeric: true, requiredOnForm: false },
	{ id: 'deliveryReliabilityPercent', numeric: true, requiredOnForm: false },
	{ id: 'agreementCancellationCount', numeric: true, requiredOnForm: false },
	{ id: 'annualExposureValue', numeric: true, requiredOnForm: false },
	{ id: 'estimatedSwitchingTime', numeric: false, requiredOnForm: false, placeholder: 'immediate / within-1-month / within-3-months / six-plus-months' },
	{ id: 'notes', numeric: false, requiredOnForm: false },
];

const QUICK_FIELD_IDS = quickFields.map((field) => field.id);
---

<PlatformShell title={`${entry ? t.instruments[entry.id]?.displayName ?? entry.displayName : 'Instrument'} · ${t.seo.titleSuffix}`} section="instruments" locale={locale}>
	{available && entry ? (
		<article class="instrument-page">
			<InstrumentHeader entry={entry} locale={locale} />
			<CapabilityPanel capabilities={entry.capabilities} locale={locale} />
			<ModeSwitcher modes={modes} instrumentId={TOOL_ID} locale={locale} />

			<!-- ============ QUICK ============ -->
			<section id="panel-quick" class="mode-panel" aria-label="Quick Check">
				<details open>
					<summary>{rt.headings.manualEntry}</summary>
					<form id="quick-form">
						<QuickForm fields={quickFields} fieldText={rt.fields} optionalWord={t.common.optionalWord} unitLabel="" />
						<div class="action-row">
							<button type="submit">{rt.buttons.runQuick}</button>
							<button type="button" class="secondary" id="quick-download-input">{rt.buttons.downloadInput}</button>
							<button type="button" class="secondary" id="quick-download-template">{rt.buttons.downloadTemplate}</button>
						</div>
					</form>
					<div id="quick-manual-issues" class="issue-box" aria-live="polite" hidden></div>
				</details>

				<details>
					<summary>{rt.headings.uploadCsv}</summary>
					<p class="section-note">{rt.labels.uploadCsvNote.replace('{filename}', 'supplier-dependency-quick-input.csv')}</p>
					<div id="quick-intake"></div>
				</details>

				<div id="quick-results-block" class="results-block" hidden>
					<h2>{rt.headings.results}</h2>
					<div id="quick-results" aria-live="polite"></div>
					<div class="action-row">
						<button type="button" class="secondary" id="quick-download-result">{rt.buttons.downloadResult}</button>
					</div>
				</div>
			</section>

			<!-- ============ ADVANCED ============ -->
			<section id="panel-advanced" class="mode-panel" aria-label="Advanced Scan" hidden>
				<details open>
					<summary>{rt.headings.manualTable}</summary>
					<p class="section-note">{rt.labels.manyRowsNote}</p>
					<div class="action-row">
						<button type="button" class="secondary" id="adv-add-row">{rt.buttons.addRow}</button>
					</div>
					<div class="table-wrap">
						<table>
							<thead>
								<tr>
									<th>{rt.fields.supplierName.label}</th><th>{rt.fields.materialName.label}</th><th>{rt.fields.materialCategory.label}</th><th>{rt.fields.supplierSharePercent.label}</th><th>{rt.fields.criticalMaterial.label}</th><th>{rt.fields.singleSource.label}</th><th>{rt.fields.qualifiedAlternativeAvailable.label}</th><th>{rt.fields.qualificationLeadTimeMonths.label}</th><th>{rt.fields.customerApprovalRequired.label}</th><th>{rt.fields.annualExposureValue.label}</th><th></th>
								</tr>
							</thead>
							<tbody id="adv-body"></tbody>
						</table>
					</div>
					<div class="action-row">
						<button type="button" class="primary" id="adv-run">{rt.buttons.runAdvanced}</button>
						<button type="button" class="secondary" id="adv-download-input">{rt.buttons.downloadInput}</button>
						<button type="button" class="secondary" id="adv-download-template">{rt.buttons.downloadTemplate}</button>
					</div>
					<div id="adv-manual-issues" class="issue-box" aria-live="polite" hidden></div>
				</details>

				<details>
					<summary>{rt.headings.uploadCsv}</summary>
					<p class="section-note">{rt.labels.uploadCsvNote.replace('{filename}', 'supplier-dependency-advanced-input.csv')}</p>
					<div id="advanced-intake"></div>
				</details>

				<div id="adv-results-block" class="results-block" hidden>
					<h2>{rt.headings.scanResults}</h2>
					<div id="adv-results" aria-live="polite"></div>
					<div class="action-row">
						<button type="button" class="secondary" id="adv-download-result">{rt.buttons.downloadResult}</button>
					</div>
				</div>
			</section>

			<section class="related" aria-labelledby="related-heading">
				<h2 id="related-heading">{t.common.relatedHeading}</h2>
				<ul>
					<li><a href={localizePath(locale, '/instruments/lead-time-gap-checker')}>{t.instruments['lead-time-gap-checker'].displayName}</a></li>
					<li><a href={localizePath(locale, '/instruments/dead-stock-scanner')}>{t.instruments['dead-stock-scanner'].displayName}</a></li>
					<li><a href={localizePath(locale, '/workspace/data-intake')}>{t.workspaces['data-intake'].displayName}</a></li>
					<li><a href={localizePath(locale, '/command')}>{t.nav.items.today}</a></li>
				</ul>
			</section>
		</article>
	) : (
		<article class="instrument-page">
			<p class="kicker">{t.common.unavailable.kicker}</p>
			<h1>{t.common.unavailable.heading}</h1>
			<p><a href={localizePath(locale, '/instruments')}>{t.common.unavailable.backLink}</a></p>
		</article>
	)}
</PlatformShell>

<script define:vars={{ locale, QUICK_FIELD_IDS }}>
	window.__WTLAB_LOCALE__ = locale;
	window.__SUPPLIER_DEP_QUICK_FIELD_IDS__ = QUICK_FIELD_IDS;
</script>

<script>
	import { confirmIntake } from '../../platform/intake/confirm.ts';
	import type { ConfirmedIntake, RawIntakeRecord } from '../../platform/intake/types.ts';
	import { validateRecords } from '../../platform/intake/validate.ts';
	import { download, el, renderIssues, setupCsvIntake } from '../../shared/intake-ui.ts';
	import { collectFormValues, initModeSwitcher, setupRowTable } from '../../shared/instrument-ui.ts';
	import { generateBlankTemplateCsv, generateInputCsv } from '../../platform/templates/generate-csv-template.ts';
	import { supplierDependencyAdvancedAdapter } from '../../platform/adapters/supplier-dependency/advanced-adapter.ts';
	import { supplierDependencyQuickAdapter } from '../../platform/adapters/supplier-dependency/quick-adapter.ts';
	import { analyzeSupplierDependency, RECOMMENDED_ACTION_MESSAGE_CODE } from '../../tools/supplier-dependency-radar/analyze.ts';
	import { validateSupplierDependencyQuickInput } from '../../tools/supplier-dependency-radar/validate.ts';
	import { supplierDependencyAdvancedResultToCsv, supplierDependencyQuickResultToCsv } from '../../tools/supplier-dependency-radar/export.ts';
	import { supplierDependencyAdvancedContract } from '../../tools/supplier-dependency-radar/modes/advanced/contract.ts';
	import { supplierDependencyAdvancedSchema } from '../../tools/supplier-dependency-radar/modes/advanced/schema.ts';
	import { supplierDependencyAdvancedTemplate } from '../../tools/supplier-dependency-radar/modes/advanced/template.ts';
	import { supplierDependencyQuickContract } from '../../tools/supplier-dependency-radar/modes/quick/contract.ts';
	import { supplierDependencyQuickSchema } from '../../tools/supplier-dependency-radar/modes/quick/schema.ts';
	import { supplierDependencyQuickTemplate } from '../../tools/supplier-dependency-radar/modes/quick/template.ts';
	import { computeSupplierDependencyPortfolio } from '../../tools/supplier-dependency-radar/portfolio.ts';
	import type { SupplierDependencyAdvancedResult } from '../../tools/supplier-dependency-radar/modes/advanced/types.ts';
	import type { SupplierAggregateInput, SupplierDependencyOutput } from '../../tools/supplier-dependency-radar/types.ts';
	import type { ValidationMessage } from '../../platform/message-codes.ts';
	import { getDictionary, resolveMessage, type Locale } from '../../i18n/index.ts';

	const locale = ((window as unknown as { __WTLAB_LOCALE__?: Locale }).__WTLAB_LOCALE__ ?? 'en') as Locale;
	const QUICK_FIELD_IDS = (window as unknown as { __SUPPLIER_DEP_QUICK_FIELD_IDS__: string[] }).__SUPPLIER_DEP_QUICK_FIELD_IDS__;
	const rt = getDictionary(locale).results.supplierDependencyRadar;
	const csvLabels = getDictionary(locale).common.csvIntake;
	const fieldLabels = Object.fromEntries(Object.entries(rt.fields).map(([id, field]) => [id, field.label]));

	initModeSwitcher();

	function fmt(value: number): string {
		return String(Math.round(value * 100) / 100);
	}
	function boolText(value: boolean | undefined): string {
		return value === undefined ? rt.labels.unknown : value ? rt.labels.yes : rt.labels.no;
	}
	function numText(value: number | undefined, unit = ''): string {
		return value === undefined ? rt.labels.unknown : `${fmt(value)}${unit}`;
	}
	function validationMessageText(e: ValidationMessage): string {
		const rawField = typeof e.params?.field === 'string' ? e.params.field : undefined;
		const params = { ...e.params, ...(rawField !== undefined ? { field: fieldLabels[rawField] ?? rawField } : {}) };
		return resolveMessage(locale, e.code, params);
	}

	// ---------- QUICK ----------

	const quickForm = document.querySelector<HTMLFormElement>('#quick-form');
	const quickManualIssues = document.getElementById('quick-manual-issues');
	const quickResultsBlock = document.getElementById('quick-results-block');
	const quickResults = document.getElementById('quick-results');
	let lastQuickResults: Array<{ supplierName: string; input: SupplierAggregateInput; output: SupplierDependencyOutput }> = [];

	function renderQuickResults(
		results: Array<{ supplierName: string; input: SupplierAggregateInput; output: SupplierDependencyOutput }>,
		failures: Array<{ supplierName: string; errors: ValidationMessage[] }>
	) {
		if (!quickResults || !quickResultsBlock) return;
		lastQuickResults = results;
		quickResults.innerHTML = '';

		for (const failure of failures) {
			const box = el('div', 'issue-box');
			box.appendChild(el('p', 'result-item-name', failure.supplierName));
			const list = el('ul');
			for (const e of failure.errors) list.appendChild(el('li', undefined, validationMessageText(e)));
			box.appendChild(list);
			box.hidden = false;
			quickResults.appendChild(box);
		}

		for (const { supplierName, output } of results) {
			const wrap = el('div', 'result-set');
			wrap.appendChild(el('p', 'result-item-name', supplierName));
			const cards = el('div', 'cards');

			const overall = el('div', 'card');
			overall.appendChild(el('h3', undefined, rt.headings.overallAssessment));
			overall.appendChild(el('p', 'card-value', rt.overallRisk[output.overallRisk].label));
			overall.appendChild(el('p', 'card-note', rt.overallRisk[output.overallRisk].description));
			if (output.primaryWarningCode) overall.appendChild(el('p', 'card-note', resolveMessage(locale, output.primaryWarningCode)));
			cards.appendChild(overall);

			const dims = el('div', 'card');
			dims.appendChild(el('h3', undefined, rt.headings.dimensions));
			const dl = el('dl');
			dl.append(
				el('dt', undefined, rt.labels.supplierDependencyLevelLabel),
				el('dd', undefined, rt.supplierDependencyLevel[output.supplierDependencyLevel]),
				el('dt', undefined, rt.labels.qualificationDependencyLevelLabel),
				el('dd', undefined, rt.qualificationDependencyLevel[output.qualificationDependencyLevel]),
				el('dt', undefined, rt.labels.switchingReadinessLabel),
				el('dd', undefined, rt.switchingReadiness[output.switchingReadiness]),
				el('dt', undefined, rt.labels.condition),
				el('dd', undefined, rt.supplyDependencyCondition[output.supplyDependencyCondition]),
				el('dt', undefined, rt.labels.criticalExposure),
				el('dd', undefined, output.criticalExposure ? rt.labels.yes : rt.labels.no),
				el('dt', undefined, rt.labels.dependencyScore),
				el('dd', undefined, fmt(output.dependencyScore))
			);
			dims.appendChild(dl);
			cards.appendChild(dims);

			const reasons = el('div', 'card');
			reasons.appendChild(el('h3', undefined, rt.headings.whyReasonCodes));
			const rlist = el('ul');
			for (const code of output.reasonCodes) rlist.appendChild(el('li', undefined, code));
			reasons.appendChild(rlist);
			cards.appendChild(reasons);

			const actions = el('div', 'card');
			actions.appendChild(el('h3', undefined, rt.headings.recommendedFocus));
			const alist = el('ul');
			for (const code of output.recommendedActionCodes) {
				alist.appendChild(el('li', undefined, resolveMessage(locale, RECOMMENDED_ACTION_MESSAGE_CODE[code])));
			}
			actions.appendChild(alist);
			cards.appendChild(actions);

			wrap.appendChild(cards);
			quickResults.appendChild(wrap);
		}

		quickResultsBlock.hidden = results.length === 0 && failures.length === 0;
		quickResultsBlock.scrollIntoView({ block: 'nearest' });
	}

	function runQuick(confirmed: ConfirmedIntake) {
		const adapted = supplierDependencyQuickAdapter(confirmed);
		if (!adapted.ok) {
			renderIssues(quickManualIssues, adapted.issues, locale, fieldLabels);
			return;
		}
		const results: Array<{ supplierName: string; input: SupplierAggregateInput; output: SupplierDependencyOutput }> = [];
		const failures: Array<{ supplierName: string; errors: ValidationMessage[] }> = [];
		for (const item of adapted.data) {
			const validated = validateSupplierDependencyQuickInput(item.input);
			if (validated.valid) {
				results.push({ supplierName: item.supplierName, input: validated.data, output: analyzeSupplierDependency(validated.data) });
			} else {
				failures.push({ supplierName: item.supplierName, errors: validated.errors });
			}
		}
		renderQuickResults(results, failures);
	}

	function quickFormRow(): Record<string, string> {
		if (!quickForm) return {};
		return collectFormValues(quickForm, QUICK_FIELD_IDS);
	}

	if (quickForm) {
		quickForm.addEventListener('submit', (event) => {
			event.preventDefault();
			const record: RawIntakeRecord = { values: quickFormRow(), unknown: {} };
			const result = validateRecords([record], supplierDependencyQuickSchema);
			if (result.errorCount > 0) {
				renderIssues(quickManualIssues, result.issues.filter((issue) => issue.severity === 'error'), locale, fieldLabels);
				return;
			}
			renderIssues(quickManualIssues, result.issues.filter((issue) => issue.severity === 'warning'), locale, fieldLabels);
			const outcome = confirmIntake(supplierDependencyQuickSchema, result);
			if (outcome.confirmed) runQuick(outcome.data);
		});
	}

	document.getElementById('quick-download-input')?.addEventListener('click', () => {
		download(supplierDependencyQuickContract.exportProfile.inputFilename, 'text/csv', generateInputCsv(supplierDependencyQuickTemplate, [quickFormRow()]));
	});
	document.getElementById('quick-download-template')?.addEventListener('click', () => {
		download('supplier-dependency-quick-template.csv', 'text/csv', generateBlankTemplateCsv(supplierDependencyQuickTemplate));
	});
	document.getElementById('quick-download-result')?.addEventListener('click', () => {
		if (lastQuickResults.length > 0) {
			const csvs = lastQuickResults.map(({ input, output }) => supplierDependencyQuickResultToCsv(input, output));
			download(supplierDependencyQuickContract.exportProfile.resultFilename, 'text/csv', csvs.join(''));
		}
	});

	setupCsvIntake('quick-intake', supplierDependencyQuickSchema, runQuick, csvLabels, locale, fieldLabels);

	// ---------- ADVANCED ----------

	const ADV_FIELDS = [
		{ id: 'supplierName' },
		{ id: 'materialName' },
		{ id: 'materialCategory' },
		{ id: 'supplierSharePercent' },
		{ id: 'criticalMaterial', placeholder: 'true/false' },
		{ id: 'singleSource', placeholder: 'true/false' },
		{ id: 'qualifiedAlternativeAvailable', placeholder: 'true/false' },
		{ id: 'qualificationLeadTimeMonths' },
		{ id: 'customerApprovalRequired', placeholder: 'true/false' },
		{ id: 'annualExposureValue' },
	];
	const advTable = setupRowTable('adv-body', ADV_FIELDS, getDictionary(locale).common.removeRow);
	const advManualIssues = document.getElementById('adv-manual-issues');
	const advResults = document.getElementById('adv-results');
	const advResultsBlock = document.getElementById('adv-results-block');
	let lastAdvResult: SupplierDependencyAdvancedResult | null = null;

	function renderAdvanced(result: SupplierDependencyAdvancedResult) {
		if (!advResults || !advResultsBlock) return;
		lastAdvResult = result;
		advResults.innerHTML = '';

		const summary = result.portfolio;
		const cards = el('div', 'cards');
		const addStat = (label: string, value: string, note?: string) => {
			const card = el('div', 'card');
			card.appendChild(el('h3', undefined, label));
			card.appendChild(el('p', 'card-value', value));
			if (note) card.appendChild(el('p', 'card-note', note));
			cards.appendChild(card);
		};
		addStat(rt.labels.totalSuppliers, String(summary.totalSuppliers));
		addStat(rt.labels.totalRelationships, String(summary.totalRelationships));
		addStat(rt.labels.totalCriticalMaterials, String(summary.totalCriticalMaterials));
		addStat(rt.labels.singleSourceMaterials, String(summary.singleSourceMaterials));
		addStat(rt.labels.qualifiedSingleSourceMaterials, String(summary.qualifiedSingleSourceMaterials));
		addStat(rt.labels.materialsWithoutQualifiedAlternative, String(summary.materialsWithoutQualifiedAlternative));
		addStat(rt.labels.materialsRequiringCustomerApproval, String(summary.materialsRequiringCustomerApproval));
		addStat(rt.labels.longQualificationTimeMaterials, String(summary.longQualificationTimeMaterials));
		addStat(
			rt.labels.exposureByRiskBand,
			(['critical', 'high', 'moderate', 'low'] as const)
				.map((band) => `${rt.overallRisk[band].label} ${fmt(summary.estimatedExposureByRiskBand[band])}`)
				.join(' · '),
			summary.relationshipsWithoutExposureData > 0 ? `${rt.labels.relationshipsWithoutExposureData}: ${summary.relationshipsWithoutExposureData}` : undefined
		);
		const summarySet = el('div', 'result-set');
		summarySet.appendChild(el('h3', undefined, rt.headings.portfolioSummary));
		summarySet.appendChild(cards);
		advResults.appendChild(summarySet);

		const supplierRank = el('div', 'result-set');
		supplierRank.appendChild(el('h3', undefined, rt.headings.supplierRanking));
		const sList = el('ol');
		for (const name of result.supplierRanking) {
			const supplier = result.suppliers.find((candidate) => candidate.supplierName === name);
			sList.appendChild(el('li', undefined, supplier ? `${name} — ${rt.overallRisk[supplier.overallRisk].label}` : name));
		}
		supplierRank.appendChild(sList);
		advResults.appendChild(supplierRank);

		const materialRank = el('div', 'result-set');
		materialRank.appendChild(el('h3', undefined, rt.headings.materialRanking));
		const mList = el('ol');
		for (const label of result.materialRanking) {
			const material = result.materials.find((candidate) => `${candidate.supplierName} · ${candidate.materialName}` === label);
			mList.appendChild(el('li', undefined, material ? `${label} — ${rt.supplyDependencyCondition[material.supplyDependencyCondition]}` : label));
		}
		materialRank.appendChild(mList);
		advResults.appendChild(materialRank);

		const supplierTableSet = el('div', 'result-set');
		supplierTableSet.appendChild(el('h3', undefined, rt.headings.supplierSummary));
		const sWrap = el('div', 'table-wrap');
		const sTable = el('table');
		const sHead = el('thead');
		const sHeadRow = el('tr');
		for (const header of [
			rt.fields.supplierName.label,
			rt.labels.materials,
			rt.labels.criticalMaterials,
			rt.labels.singleSourceCount,
			rt.labels.qualifiedSingleSourceCount,
			rt.labels.averageShare,
			rt.headings.overallAssessment,
			rt.labels.reasons,
		]) {
			sHeadRow.appendChild(el('th', undefined, header));
		}
		sHead.appendChild(sHeadRow);
		sTable.appendChild(sHead);
		const sBody = el('tbody');
		for (const supplier of result.suppliers) {
			const tr = el('tr');
			tr.append(
				el('td', undefined, supplier.supplierName),
				el('td', undefined, String(supplier.materialCount)),
				el('td', undefined, String(supplier.criticalMaterialCount)),
				el('td', undefined, String(supplier.singleSourceCount)),
				el('td', undefined, String(supplier.qualifiedSingleSourceCount)),
				el('td', undefined, `${fmt(supplier.averageSupplierSharePercent)}%`),
				el('td', supplier.overallRisk === 'critical' || supplier.overallRisk === 'high' ? 'cell-high' : undefined, rt.overallRisk[supplier.overallRisk].label),
				el('td', undefined, supplier.reasonCodes.join(', '))
			);
			sBody.appendChild(tr);
		}
		sTable.appendChild(sBody);
		sWrap.appendChild(sTable);
		supplierTableSet.appendChild(sWrap);
		advResults.appendChild(supplierTableSet);

		const materialTableSet = el('div', 'result-set');
		materialTableSet.appendChild(el('h3', undefined, rt.headings.materialRisk));
		const mWrap = el('div', 'table-wrap');
		const mTable = el('table');
		const mHead = el('thead');
		const mHeadRow = el('tr');
		for (const header of [
			rt.fields.supplierName.label,
			rt.fields.materialName.label,
			rt.labels.condition,
			rt.fields.criticalMaterial.label,
			rt.fields.qualifiedAlternativeAvailable.label,
			rt.fields.qualificationLeadTimeMonths.label,
			rt.labels.estimatedExposure,
			rt.labels.reasons,
		]) {
			mHeadRow.appendChild(el('th', undefined, header));
		}
		mHead.appendChild(mHeadRow);
		mTable.appendChild(mHead);
		const mBody = el('tbody');
		for (const material of result.materials) {
			const tr = el('tr');
			tr.append(
				el('td', undefined, material.supplierName),
				el('td', undefined, material.materialName),
				el('td', material.riskLevel === 'critical' || material.riskLevel === 'high' ? 'cell-high' : undefined, rt.supplyDependencyCondition[material.supplyDependencyCondition]),
				el('td', undefined, boolText(material.criticalMaterial)),
				el('td', undefined, boolText(material.qualifiedAlternativeAvailable)),
				el('td', undefined, numText(material.qualificationLeadTimeMonths, ` ${rt.labels.monthsUnit}`)),
				el('td', undefined, material.annualExposureValue === undefined ? rt.labels.exposureUnknown : fmt(material.annualExposureValue)),
				el('td', undefined, material.reasonCodes.join(', '))
			);
			mBody.appendChild(tr);
		}
		mTable.appendChild(mBody);
		mWrap.appendChild(mTable);
		materialTableSet.appendChild(mWrap);
		advResults.appendChild(materialTableSet);

		advResultsBlock.hidden = false;
		advResultsBlock.scrollIntoView({ block: 'nearest' });
	}

	function runAdvanced(confirmed: ConfirmedIntake) {
		const adapted = supplierDependencyAdvancedAdapter(confirmed);
		if (!adapted.ok) {
			renderIssues(advManualIssues, adapted.issues, locale, fieldLabels);
			return;
		}
		renderIssues(advManualIssues, [], locale, fieldLabels);
		renderAdvanced(computeSupplierDependencyPortfolio(adapted.data));
	}

	function advLongRows(): Array<Record<string, string>> {
		return advTable.rows();
	}

	document.getElementById('adv-add-row')?.addEventListener('click', () => advTable.addRow());
	document.getElementById('adv-run')?.addEventListener('click', () => {
		const records: RawIntakeRecord[] = advLongRows().map((values) => ({ values, unknown: {} }));
		const result = validateRecords(records, supplierDependencyAdvancedSchema);
		if (result.errorCount > 0) {
			renderIssues(advManualIssues, result.issues.filter((issue) => issue.severity === 'error'), locale, fieldLabels);
			return;
		}
		const outcome = confirmIntake(supplierDependencyAdvancedSchema, result);
		if (outcome.confirmed) runAdvanced(outcome.data);
	});
	document.getElementById('adv-download-input')?.addEventListener('click', () => {
		download(supplierDependencyAdvancedContract.exportProfile.inputFilename, 'text/csv', generateInputCsv(supplierDependencyAdvancedTemplate, advLongRows()));
	});
	document.getElementById('adv-download-template')?.addEventListener('click', () => {
		download('supplier-dependency-advanced-template.csv', 'text/csv', generateBlankTemplateCsv(supplierDependencyAdvancedTemplate));
	});
	document.getElementById('adv-download-result')?.addEventListener('click', () => {
		if (lastAdvResult) {
			download(supplierDependencyAdvancedContract.exportProfile.resultFilename, 'text/csv', supplierDependencyAdvancedResultToCsv(lastAdvResult));
		}
	});
	setupCsvIntake('advanced-intake', supplierDependencyAdvancedSchema, runAdvanced, csvLabels, locale, fieldLabels);
</script>

