---
// Buffer Drift Monitor — fifth production instrument (Sprint 008), one
// shared implementation across both locales. The first instrument built
// entirely on the mature factory including the Quick Form Generator
// (QuickForm.astro) — no hand-rolled form markup here at all.
import '../../shared/instrument.css';
import CapabilityPanel from '../../components/CapabilityPanel.astro';
import InstrumentHeader from '../../components/InstrumentHeader.astro';
import ModeSwitcher from '../../components/ModeSwitcher.astro';
import QuickForm from '../../components/QuickForm.astro';
import PlatformShell from '../../layouts/PlatformShell.astro';
import { getDictionary, localizePath, type Locale } from '../../i18n';
import { findById } from '../../platform/catalog';
import { instruments } from '../../platform/instruments';
import type { QuickFormFieldConfig } from '../../platform/quick-form';
import { platformRegistry } from '../../platform/registry';
import { bufferDriftAdvancedContract } from '../../tools/buffer-drift-monitor/modes/advanced/contract';
import { bufferDriftQuickContract } from '../../tools/buffer-drift-monitor/modes/quick/contract';

interface Props {
	locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = getDictionary(locale);
const rt = t.results.bufferDriftMonitor;

const TOOL_ID = 'buffer-drift-monitor';
const available = platformRegistry.isAvailable(TOOL_ID);
const entry = findById(instruments, TOOL_ID);
const modes = [bufferDriftQuickContract, bufferDriftAdvancedContract];

const quickFields: QuickFormFieldConfig[] = [
	{ id: 'itemName', numeric: false, requiredOnForm: false },
	{ id: 'monthlyConsumption', numeric: true, requiredOnForm: true },
	{ id: 'intendedBufferMonths', numeric: true, requiredOnForm: true },
	{ id: 'actualBufferQuantity', numeric: true, requiredOnForm: true },
];
---

<PlatformShell title={`${entry ? t.instruments[entry.id]?.displayName ?? entry.displayName : 'Instrument'} · ${t.seo.titleSuffix}`} section="instruments" locale={locale}>
	{available && entry ? (
		<article class="instrument-page">
			<InstrumentHeader entry={entry} locale={locale} />
			<CapabilityPanel capabilities={entry.capabilities} locale={locale} />
			<ModeSwitcher modes={modes} instrumentId={TOOL_ID} locale={locale} />

			<!-- ============ QUICK ============ -->
			<section id="panel-quick" class="mode-panel" aria-label="Quick Check">
				<details open>
					<summary>{rt.headings.manualEntry}</summary>
					<form id="quick-form">
						<QuickForm fields={quickFields} fieldText={rt.fields} optionalWord={t.common.optionalWord} unitLabel="" />
						<div class="action-row">
							<button type="submit">{rt.buttons.runQuick}</button>
							<button type="button" class="secondary" id="quick-download-input">{rt.buttons.downloadInput}</button>
							<button type="button" class="secondary" id="quick-download-template">{rt.buttons.downloadTemplate}</button>
						</div>
					</form>
					<div id="quick-manual-issues" class="issue-box" aria-live="polite" hidden></div>
				</details>

				<details>
					<summary>{rt.headings.uploadCsv}</summary>
					<p class="section-note">{rt.labels.uploadCsvNote.replace('{filename}', 'buffer-drift-quick-input.csv')}</p>
					<div id="quick-intake"></div>
				</details>

				<div id="quick-results-block" class="results-block" hidden>
					<h2>{rt.headings.results}</h2>
					<div id="quick-results" aria-live="polite"></div>
					<div class="action-row">
						<button type="button" class="secondary" id="quick-download-result">{rt.buttons.downloadResult}</button>
					</div>
				</div>
			</section>

			<!-- ============ ADVANCED ============ -->
			<section id="panel-advanced" class="mode-panel" aria-label="Advanced Tracking" hidden>
				<details open>
					<summary>{rt.headings.manualTable}</summary>
					<p class="section-note">{rt.labels.manualTableNote}</p>
					<div class="action-row">
						<button type="button" class="secondary" id="adv-add-item">{rt.buttons.addItem}</button>
						<button type="button" class="secondary" id="adv-add-period">{rt.buttons.addPeriod}</button>
						<button type="button" class="secondary" id="adv-remove-period">{rt.buttons.removePeriod}</button>
					</div>
					<div class="table-wrap">
						<table id="adv-table">
							<thead id="adv-head"></thead>
							<tbody id="adv-body"></tbody>
						</table>
					</div>
					<div class="action-row">
						<button type="button" class="primary" id="adv-run">{rt.buttons.runAdvanced}</button>
						<button type="button" class="secondary" id="adv-download-input">{rt.buttons.downloadInput}</button>
						<button type="button" class="secondary" id="adv-download-template">{rt.buttons.downloadTemplate}</button>
					</div>
					<div id="adv-manual-issues" class="issue-box" aria-live="polite" hidden></div>
				</details>

				<details>
					<summary>{rt.headings.uploadCsv}</summary>
					<p class="section-note">{rt.labels.uploadCsvNote.replace('{filename}', 'buffer-drift-advanced-input.csv')}</p>
					<div id="advanced-intake"></div>
				</details>

				<div id="adv-results-block" class="results-block" hidden>
					<h2>{rt.headings.trackingResults}</h2>
					<div id="adv-results" aria-live="polite"></div>
					<div class="action-row">
						<button type="button" class="secondary" id="adv-download-result">{rt.buttons.downloadResult}</button>
					</div>
				</div>
			</section>

			<section class="related" aria-labelledby="related-heading">
				<h2 id="related-heading">{t.common.relatedHeading}</h2>
				<ul>
					<li><a href={localizePath(locale, '/tools/inventory-buffer-check')}>{t.instruments['inventory-buffer-check'].displayName}</a></li>
					<li><a href={localizePath(locale, '/instruments/lead-time-gap-checker')}>{t.instruments['lead-time-gap-checker'].displayName}</a></li>
					<li><a href={localizePath(locale, '/instruments/dead-stock-scanner')}>{t.instruments['dead-stock-scanner'].displayName}</a></li>
					<li><a href={localizePath(locale, '/workspace/data-intake')}>{t.workspaces['data-intake'].displayName}</a></li>
					<li><a href={localizePath(locale, '/command')}>{t.nav.items.today}</a></li>
				</ul>
			</section>
		</article>
	) : (
		<article class="instrument-page">
			<p class="kicker">{t.common.unavailable.kicker}</p>
			<h1>{t.common.unavailable.heading}</h1>
			<p><a href={localizePath(locale, '/instruments')}>{t.common.unavailable.backLink}</a></p>
		</article>
	)}
</PlatformShell>

<script define:vars={{ locale }}>
	window.__WTLAB_LOCALE__ = locale;
</script>

<script>
	import { confirmIntake } from '../../platform/intake/confirm.ts';
	import type { ConfirmedIntake, RawIntakeRecord } from '../../platform/intake/types.ts';
	import { validateRecords } from '../../platform/intake/validate.ts';
	import { download, el, renderIssues, setupCsvIntake } from '../../shared/intake-ui.ts';
	import { collectFormValues, initModeSwitcher } from '../../shared/instrument-ui.ts';
	import { generateBlankTemplateCsv, generateInputCsv } from '../../platform/templates/generate-csv-template.ts';
	import { bufferDriftAdvancedAdapter } from '../../platform/adapters/buffer-drift/advanced-adapter.ts';
	import { bufferDriftQuickAdapter } from '../../platform/adapters/buffer-drift/quick-adapter.ts';
	import { analyzeBufferDrift } from '../../tools/buffer-drift-monitor/analyze.ts';
	import { validateBufferDriftInput } from '../../tools/buffer-drift-monitor/validate.ts';
	import { bufferDriftProjectionToCsv, bufferDriftQuickResultsToCsv } from '../../tools/buffer-drift-monitor/export.ts';
	import { bufferDriftAdvancedContract } from '../../tools/buffer-drift-monitor/modes/advanced/contract.ts';
	import { bufferDriftAdvancedSchema } from '../../tools/buffer-drift-monitor/modes/advanced/schema.ts';
	import { bufferDriftAdvancedTemplate } from '../../tools/buffer-drift-monitor/modes/advanced/template.ts';
	import { bufferDriftQuickContract } from '../../tools/buffer-drift-monitor/modes/quick/contract.ts';
	import { bufferDriftQuickSchema } from '../../tools/buffer-drift-monitor/modes/quick/schema.ts';
	import { bufferDriftQuickTemplate } from '../../tools/buffer-drift-monitor/modes/quick/template.ts';
	import { computeBufferDriftProjection } from '../../tools/buffer-drift-monitor/projection.ts';
	import type { BufferDriftProjectionResult } from '../../tools/buffer-drift-monitor/modes/advanced/types.ts';
	import type { BufferDriftOutput } from '../../tools/buffer-drift-monitor/types.ts';
	import type { ValidationMessage } from '../../platform/message-codes.ts';
	import { getDictionary, resolveMessage, type Locale } from '../../i18n/index.ts';

	const locale = ((window as unknown as { __WTLAB_LOCALE__?: Locale }).__WTLAB_LOCALE__ ?? 'en') as Locale;
	const rt = getDictionary(locale).results.bufferDriftMonitor;
	const csvLabels = getDictionary(locale).common.csvIntake;
	const fieldLabels = Object.fromEntries(Object.entries(rt.fields).map(([id, field]) => [id, field.label]));

	initModeSwitcher();

	function fmt(value: number): string {
		return String(Math.round(value * 100) / 100);
	}

	function validationMessageText(e: ValidationMessage): string {
		const rawField = typeof e.params?.field === 'string' ? e.params.field : undefined;
		const params = { ...e.params, ...(rawField !== undefined ? { field: fieldLabels[rawField] ?? rawField } : {}) };
		return resolveMessage(locale, e.code, params);
	}

	// ---------- QUICK ----------

	const quickForm = document.querySelector<HTMLFormElement>('#quick-form');
	const quickManualIssues = document.getElementById('quick-manual-issues');
	const quickResultsBlock = document.getElementById('quick-results-block');
	const quickResults = document.getElementById('quick-results');
	let lastQuickResults: Array<{ itemName: string; output: BufferDriftOutput }> = [];

	function renderQuickResults(
		results: Array<{ itemName: string; output: BufferDriftOutput }>,
		failures: Array<{ itemName: string; errors: ValidationMessage[] }>
	) {
		if (!quickResults || !quickResultsBlock) return;
		lastQuickResults = results;
		quickResults.innerHTML = '';

		for (const failure of failures) {
			const box = el('div', 'issue-box');
			box.appendChild(el('p', 'result-item-name', failure.itemName));
			const list = el('ul');
			for (const e of failure.errors) list.appendChild(el('li', undefined, validationMessageText(e)));
			box.appendChild(list);
			box.hidden = false;
			quickResults.appendChild(box);
		}

		for (const { itemName, output } of results) {
			const wrap = el('div', 'result-set');
			wrap.appendChild(el('p', 'result-item-name', itemName));
			const cards = el('div', 'cards');

			const statusCard = el('div', 'card');
			statusCard.appendChild(el('h3', undefined, rt.headings.driftAssessment));
			const status = rt.status[output.status];
			statusCard.appendChild(el('p', 'card-value', status.label));
			statusCard.appendChild(el('p', 'card-note', status.description));
			if (output.primaryWarningCode) statusCard.appendChild(el('p', 'card-note', resolveMessage(locale, output.primaryWarningCode)));
			statusCard.appendChild(el('p', 'card-note', resolveMessage(locale, output.recommendedActionCode)));
			cards.appendChild(statusCard);

			const numbers = el('div', 'card');
			numbers.appendChild(el('h3', undefined, rt.headings.numbers));
			const dl = el('dl');
			dl.append(
				el('dt', undefined, rt.labels.intendedQuantity),
				el('dd', undefined, fmt(output.intendedBufferQuantity)),
				el('dt', undefined, rt.labels.actualMonths),
				el('dd', undefined, output.actualBufferMonths === undefined ? rt.labels.noConsumption : fmt(output.actualBufferMonths)),
				el('dt', undefined, rt.labels.driftMonths),
				el('dd', undefined, output.driftMonths === undefined ? rt.labels.notApplicable : fmt(output.driftMonths)),
				el('dt', undefined, rt.labels.driftQuantity),
				el('dd', undefined, fmt(output.driftQuantity)),
				el('dt', undefined, rt.labels.driftPercent),
				el('dd', undefined, output.driftPercent === undefined ? rt.labels.notApplicable : `${fmt(output.driftPercent)}%`)
			);
			numbers.appendChild(dl);
			cards.appendChild(numbers);

			const reasons = el('div', 'card');
			reasons.appendChild(el('h3', undefined, rt.labels.reasons));
			const list = el('ul');
			// Reason codes are stable machine codes — never translated.
			for (const code of output.reasonCodes) list.appendChild(el('li', undefined, code));
			reasons.appendChild(list);
			cards.appendChild(reasons);

			wrap.appendChild(cards);
			quickResults.appendChild(wrap);
		}

		quickResultsBlock.hidden = results.length === 0 && failures.length === 0;
		quickResultsBlock.scrollIntoView({ block: 'nearest' });
	}

	function runQuick(confirmed: ConfirmedIntake) {
		const adapted = bufferDriftQuickAdapter(confirmed);
		if (!adapted.ok) {
			renderIssues(quickManualIssues, adapted.issues, locale, fieldLabels);
			return;
		}
		const results: Array<{ itemName: string; output: BufferDriftOutput }> = [];
		const failures: Array<{ itemName: string; errors: ValidationMessage[] }> = [];
		for (const item of adapted.data) {
			const validated = validateBufferDriftInput(item.input);
			if (validated.valid) {
				results.push({ itemName: item.itemName, output: analyzeBufferDrift(validated.data) });
			} else {
				failures.push({ itemName: item.itemName, errors: validated.errors });
			}
		}
		renderQuickResults(results, failures);
	}

	function quickFormRow(): Record<string, string> {
		if (!quickForm) return {};
		const values = collectFormValues(quickForm, ['itemName', 'monthlyConsumption', 'intendedBufferMonths', 'actualBufferQuantity']);
		return {
			itemName: values.itemName === '' ? 'item-1' : values.itemName,
			monthlyConsumption: values.monthlyConsumption,
			intendedBufferMonths: values.intendedBufferMonths,
			actualBufferQuantity: values.actualBufferQuantity,
		};
	}

	if (quickForm) {
		quickForm.addEventListener('submit', (event) => {
			event.preventDefault();
			const record: RawIntakeRecord = { values: quickFormRow(), unknown: {} };
			const result = validateRecords([record], bufferDriftQuickSchema);
			if (result.errorCount > 0) {
				renderIssues(quickManualIssues, result.issues.filter((issue) => issue.severity === 'error'), locale, fieldLabels);
				return;
			}
			renderIssues(quickManualIssues, [], locale, fieldLabels);
			const outcome = confirmIntake(bufferDriftQuickSchema, result);
			if (outcome.confirmed) runQuick(outcome.data);
		});
	}

	document.getElementById('quick-download-input')?.addEventListener('click', () => {
		download(bufferDriftQuickContract.exportProfile.inputFilename, 'text/csv', generateInputCsv(bufferDriftQuickTemplate, [quickFormRow()]));
	});
	document.getElementById('quick-download-template')?.addEventListener('click', () => {
		download('buffer-drift-quick-template.csv', 'text/csv', generateBlankTemplateCsv(bufferDriftQuickTemplate));
	});
	document.getElementById('quick-download-result')?.addEventListener('click', () => {
		if (lastQuickResults.length > 0) {
			download(bufferDriftQuickContract.exportProfile.resultFilename, 'text/csv', bufferDriftQuickResultsToCsv(lastQuickResults));
		}
	});

	setupCsvIntake('quick-intake', bufferDriftQuickSchema, runQuick, csvLabels, locale, fieldLabels);

	// ---------- ADVANCED MODE ----------

	const advHead = document.getElementById('adv-head');
	const advBody = document.getElementById('adv-body');
	const advManualIssues = document.getElementById('adv-manual-issues');
	const advResultsBlock = document.getElementById('adv-results-block');
	const advResults = document.getElementById('adv-results');
	let advPeriods = 3;
	let advItemSeq = 0;
	let lastProjection: BufferDriftProjectionResult | null = null;

	function advRenderHead() {
		if (!advHead) return;
		advHead.innerHTML = '';
		const row = el('tr');
		row.append(el('th', undefined, rt.fields.itemName.label), el('th', undefined, rt.fields.intendedBufferMonths.label));
		for (let p = 1; p <= advPeriods; p++) {
			row.append(el('th', undefined, `P${p} ${rt.fields.monthlyConsumption.label}`), el('th', undefined, `P${p} ${rt.fields.actualBufferQuantity.label}`));
		}
		row.append(el('th', undefined, ''));
		advHead.appendChild(row);
	}

	function advAddItemRow(prefill?: Record<string, string>) {
		if (!advBody) return;
		advItemSeq += 1;
		const row = el('tr');
		const mkCell = (name: string, value = '') => {
			const cell = el('td');
			const input = el('input') as HTMLInputElement;
			input.type = 'text';
			input.dataset.field = name;
			input.value = value;
			input.setAttribute('aria-label', name);
			cell.appendChild(input);
			return cell;
		};
		row.appendChild(mkCell('itemName', prefill?.itemName ?? `item-${advItemSeq}`));
		row.appendChild(mkCell('intendedBufferMonths', prefill?.intendedBufferMonths ?? ''));
		for (let p = 1; p <= advPeriods; p++) {
			row.appendChild(mkCell(`consumption-${p}`));
			row.appendChild(mkCell(`buffer-${p}`));
		}
		const removeCell = el('td');
		const removeBtn = el('button', 'secondary', rt.buttons.remove) as HTMLButtonElement;
		removeBtn.type = 'button';
		removeBtn.addEventListener('click', () => row.remove());
		removeCell.appendChild(removeBtn);
		row.appendChild(removeCell);
		advBody.appendChild(row);
	}

	function advSetPeriods(count: number) {
		const previous: Array<Record<string, string>> = advCollectCells();
		advPeriods = Math.max(1, count);
		advRenderHead();
		if (advBody) advBody.innerHTML = '';
		advItemSeq = 0;
		if (previous.length === 0) {
			advAddItemRow();
		} else {
			for (const cells of previous) {
				advAddItemRow(cells);
				const row = advBody?.lastElementChild;
				if (row) {
					for (const input of row.querySelectorAll<HTMLInputElement>('input')) {
						const key = input.dataset.field ?? '';
						if (cells[key] !== undefined) input.value = cells[key];
					}
				}
			}
		}
	}

	function advCollectCells(): Array<Record<string, string>> {
		if (!advBody) return [];
		return Array.from(advBody.querySelectorAll('tr')).map((row) => {
			const cells: Record<string, string> = {};
			for (const input of row.querySelectorAll<HTMLInputElement>('input')) {
				cells[input.dataset.field ?? ''] = input.value;
			}
			return cells;
		});
	}

	/** Manual table → long-format rows (same contract as the CSV). */
	function advLongRows(): Array<Record<string, string>> {
		return advCollectCells().flatMap((cells) => {
			const rows: Array<Record<string, string>> = [];
			for (let p = 1; p <= advPeriods; p++) {
				rows.push({
					itemName: cells['itemName'] ?? '',
					period: String(p),
					intendedBufferMonths: p === 1 ? (cells['intendedBufferMonths'] ?? '') : '',
					monthlyConsumption: cells[`consumption-${p}`] ?? '',
					actualBufferQuantity: cells[`buffer-${p}`] ?? '',
				});
			}
			return rows;
		});
	}

	function renderProjection(projection: BufferDriftProjectionResult) {
		if (!advResults || !advResultsBlock) return;
		lastProjection = projection;
		advResults.innerHTML = '';

		const ranking = el('div', 'result-set');
		ranking.appendChild(el('h3', undefined, rt.headings.riskPriority));
		const rankList = el('ol');
		for (const name of projection.riskRanking) {
			const item = projection.items.find((candidate) => candidate.name === name);
			const label = item ? `${name} — ${rt.status[item.latestStatus].label} (${rt.labels.trend}: ${rt.trend[item.trend]})` : name;
			rankList.appendChild(el('li', undefined, label));
		}
		ranking.appendChild(rankList);
		advResults.appendChild(ranking);

		for (const item of projection.items) {
			const wrap = el('div', 'result-set');
			wrap.appendChild(el('p', 'result-item-name', `${item.name} · ${rt.fields.intendedBufferMonths.label} ${fmt(item.intendedBufferMonths)} · ${rt.labels.trend}: ${rt.trend[item.trend]}`));
			const tableWrap = el('div', 'table-wrap');
			const table = el('table');
			const thead = el('thead');
			const headRow = el('tr');
			headRow.append(
				el('th', undefined, rt.labels.period),
				el('th', undefined, rt.fields.monthlyConsumption.label),
				el('th', undefined, rt.fields.actualBufferQuantity.label),
				el('th', undefined, rt.labels.driftPercent),
				el('th', undefined, rt.labels.status)
			);
			thead.appendChild(headRow);
			table.appendChild(thead);
			const tbody = el('tbody');
			for (const period of item.periods) {
				const tr = el('tr');
				const severe = period.status === 'severely-under-buffered' || period.status === 'severely-over-buffered';
				const moderate = period.status === 'under-buffered' || period.status === 'over-buffered';
				tr.append(
					el('td', undefined, String(period.period)),
					el('td', undefined, String(period.monthlyConsumption)),
					el('td', undefined, String(period.actualBufferQuantity)),
					el('td', undefined, period.driftPercent === undefined ? rt.labels.notApplicable : `${fmt(period.driftPercent)}%`),
					el('td', severe ? 'cell-shortage' : moderate ? 'cell-breach' : undefined, rt.status[period.status].label)
				);
				tbody.appendChild(tr);
			}
			table.appendChild(tbody);
			tableWrap.appendChild(table);
			wrap.appendChild(tableWrap);
			advResults.appendChild(wrap);
		}

		advResultsBlock.hidden = false;
		advResultsBlock.scrollIntoView({ block: 'nearest' });
	}

	function runAdvanced(confirmed: ConfirmedIntake) {
		const adapted = bufferDriftAdvancedAdapter(confirmed);
		if (!adapted.ok) {
			renderIssues(advManualIssues, adapted.issues, locale, fieldLabels);
			return;
		}
		renderIssues(advManualIssues, [], locale, fieldLabels);
		renderProjection(computeBufferDriftProjection(adapted.data));
	}

	document.getElementById('adv-add-item')?.addEventListener('click', () => advAddItemRow());
	document.getElementById('adv-add-period')?.addEventListener('click', () => advSetPeriods(advPeriods + 1));
	document.getElementById('adv-remove-period')?.addEventListener('click', () => advSetPeriods(advPeriods - 1));

	document.getElementById('adv-run')?.addEventListener('click', () => {
		const records: RawIntakeRecord[] = advLongRows().map((values) => ({ values, unknown: {} }));
		const result = validateRecords(records, bufferDriftAdvancedSchema);
		if (result.errorCount > 0) {
			renderIssues(advManualIssues, result.issues.filter((issue) => issue.severity === 'error'), locale, fieldLabels);
			return;
		}
		const outcome = confirmIntake(bufferDriftAdvancedSchema, result);
		if (outcome.confirmed) runAdvanced(outcome.data);
	});

	document.getElementById('adv-download-input')?.addEventListener('click', () => {
		download(bufferDriftAdvancedContract.exportProfile.inputFilename, 'text/csv', generateInputCsv(bufferDriftAdvancedTemplate, advLongRows()));
	});
	document.getElementById('adv-download-template')?.addEventListener('click', () => {
		download('buffer-drift-advanced-template.csv', 'text/csv', generateBlankTemplateCsv(bufferDriftAdvancedTemplate));
	});
	document.getElementById('adv-download-result')?.addEventListener('click', () => {
		if (lastProjection) {
			download(bufferDriftAdvancedContract.exportProfile.resultFilename, 'text/csv', bufferDriftProjectionToCsv(lastProjection));
		}
	});

	setupCsvIntake('advanced-intake', bufferDriftAdvancedSchema, runAdvanced, csvLabels, locale, fieldLabels);

	// Initial advanced table state.
	advRenderHead();
	advAddItemRow();
</script>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
	}

	:global(#adv-table input) {
		min-width: 6rem;
	}

	:global(.cell-shortage) {
		color: var(--color-accent-strong);
		font-weight: 600;
	}

	:global(.cell-breach) {
		color: var(--color-accent);
	}
</style>
