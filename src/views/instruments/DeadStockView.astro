---
// Dead Stock Scanner — one shared implementation across both locales.
// `item.primaryWarning` / `item.recommendedAction` carry a stable
// `*Code` alongside their English text (Sprint 006, Task 014); the client
// script resolves them through the current locale. `item.reasonCodes`
// remain stable machine codes (Task 007: reason codes are never
// translated) — those stay as-is regardless of locale.
import '../../shared/instrument.css';
import CapabilityPanel from '../../components/CapabilityPanel.astro';
import InstrumentHeader from '../../components/InstrumentHeader.astro';
import ModeSwitcher from '../../components/ModeSwitcher.astro';
import PlatformShell from '../../layouts/PlatformShell.astro';
import { getDictionary, localizePath, type Locale } from '../../i18n';
import { findById } from '../../platform/catalog';
import { instruments } from '../../platform/instruments';
import { platformRegistry } from '../../platform/registry';
import { deadStockAdvancedContract } from '../../tools/dead-stock-scanner/modes/advanced/contract';
import { deadStockQuickContract } from '../../tools/dead-stock-scanner/modes/quick/contract';

interface Props {
	locale?: Locale;
}
const { locale = 'en' } = Astro.props;
const t = getDictionary(locale);
const rt = t.results.deadStockScanner;

const TOOL_ID = 'dead-stock-scanner';
const available = platformRegistry.isAvailable(TOOL_ID);
const entry = findById(instruments, TOOL_ID);
const modes = [deadStockQuickContract, deadStockAdvancedContract];

const quickFieldOrder = [
	'item',
	'currentStock',
	'recentMonthlyConsumption',
	'monthsSinceLastMovement',
	'futureDemand',
	'unitCost',
	'thresholdMonths',
] as const;
const requiredFields = new Set(['item', 'currentStock', 'recentMonthlyConsumption']);
const quickFields = quickFieldOrder.map((id) => ({
	id,
	required: requiredFields.has(id),
	...rt.fields[id],
}));
---

<PlatformShell title={`${entry ? t.instruments[entry.id]?.displayName ?? entry.displayName : 'Instrument'} · ${t.seo.titleSuffix}`} section="instruments" locale={locale}>
	{available && entry ? (
		<article class="instrument-page">
			<InstrumentHeader entry={entry} locale={locale} />
			<CapabilityPanel capabilities={entry.capabilities} locale={locale} />
			<ModeSwitcher modes={modes} instrumentId={TOOL_ID} locale={locale} />

			<!-- ============ QUICK ============ -->
			<section id="panel-quick" class="mode-panel" aria-label="Quick Check">
				<details open>
					<summary>{rt.headings.manualEntry}</summary>
					<form id="quick-form">
						{quickFields.map((field) => (
							<div class="field">
								<label for={`q-${field.id}`}>
									{field.label}
									{field.required ? '' : <span class="optional-marker"> ({t.common.optionalWord}{field.optional ? ` — ${field.optional}` : ''})</span>}
									{field.required && field.optional ? <span class="optional-marker"> ({field.optional})</span> : ''}
								</label>
								<input id={`q-${field.id}`} name={field.id} type="text" inputmode={field.id === 'item' ? undefined : 'decimal'} required={field.required} />
							</div>
						))}
						<div class="action-row">
							<button type="submit">{rt.buttons.runQuick}</button>
							<button type="button" class="secondary" id="quick-download-input">{rt.buttons.downloadInput}</button>
							<button type="button" class="secondary" id="quick-download-template">{rt.buttons.downloadTemplate}</button>
						</div>
					</form>
					<div id="quick-manual-issues" class="issue-box" aria-live="polite" hidden></div>
				</details>

				<details>
					<summary>{rt.headings.uploadCsv}</summary>
					<p class="section-note">{rt.labels.uploadCsvNote.replace('{filename}', 'dead-stock-quick-input.csv')}</p>
					<div id="quick-intake"></div>
				</details>

				<div id="quick-results-block" class="results-block" hidden>
					<h2>{rt.headings.result}</h2>
					<div id="quick-results" aria-live="polite"></div>
					<div class="action-row">
						<button type="button" class="secondary" id="quick-download-result">{rt.buttons.downloadResult}</button>
					</div>
				</div>
			</section>

			<!-- ============ ADVANCED ============ -->
			<section id="panel-advanced" class="mode-panel" aria-label="Advanced Scan" hidden>
				<details open>
					<summary>{rt.headings.manualTable}</summary>
					<p class="section-note">{rt.labels.manyRowsNote}</p>
					<div class="action-row">
						<button type="button" class="secondary" id="adv-add-row">{rt.buttons.addItem}</button>
					</div>
					<div class="table-wrap">
						<table>
							<thead>
								<tr>
									<th>{rt.fields.item.label}</th><th>{rt.fields.currentStock.label}</th><th>{rt.fields.recentMonthlyConsumption.label}</th><th>{rt.fields.monthsSinceLastMovement.label}</th><th>{rt.fields.futureDemand.label}</th><th>{rt.fields.unitCost.label}</th><th>{rt.fields.category.label}</th><th></th>
								</tr>
							</thead>
							<tbody id="adv-body"></tbody>
						</table>
					</div>
					<div class="action-row">
						<button type="button" class="primary" id="adv-run">{rt.buttons.runAdvanced}</button>
						<button type="button" class="secondary" id="adv-download-input">{rt.buttons.downloadInput}</button>
						<button type="button" class="secondary" id="adv-download-template">{rt.buttons.downloadTemplate}</button>
					</div>
					<div id="adv-manual-issues" class="issue-box" aria-live="polite" hidden></div>
				</details>

				<details>
					<summary>{rt.headings.uploadCsv}</summary>
					<p class="section-note">{rt.labels.uploadCsvNote.replace('{filename}', 'dead-stock-advanced-input.csv')}</p>
					<div id="advanced-intake"></div>
				</details>

				<div id="adv-results-block" class="results-block" hidden>
					<h2>{rt.headings.scanResults}</h2>
					<div id="adv-results" aria-live="polite"></div>
					<div class="action-row">
						<button type="button" class="secondary" id="adv-download-result">{rt.buttons.downloadResult}</button>
					</div>
				</div>
			</section>

			<section class="related" aria-labelledby="related-heading">
				<h2 id="related-heading">{t.common.relatedHeading}</h2>
				<ul>
					<li><a href={localizePath(locale, '/tools/inventory-buffer-check')}>{t.instruments['inventory-buffer-check'].displayName}</a></li>
					<li><a href={localizePath(locale, '/instruments/arrival-collision-detector')}>{t.instruments['arrival-collision-detector'].displayName}</a></li>
					<li><a href={localizePath(locale, '/workspace/data-intake')}>{t.workspaces['data-intake'].displayName}</a></li>
					<li><a href={localizePath(locale, '/command')}>{t.nav.items.today}</a></li>
				</ul>
			</section>
		</article>
	) : (
		<article class="instrument-page">
			<p class="kicker">{t.common.unavailable.kicker}</p>
			<h1>{t.common.unavailable.heading}</h1>
			<p><a href={localizePath(locale, '/instruments')}>{t.common.unavailable.backLink}</a></p>
		</article>
	)}
</PlatformShell>

<script define:vars={{ locale }}>
	window.__WTLAB_LOCALE__ = locale;
</script>

<script>
	import { confirmIntake } from '../../platform/intake/confirm.ts';
	import type { ConfirmedIntake, RawIntakeRecord } from '../../platform/intake/types.ts';
	import { validateRecords } from '../../platform/intake/validate.ts';
	import { download, el, renderIssues, setupCsvIntake } from '../../shared/intake-ui.ts';
	import { initModeSwitcher, setupRowTable } from '../../shared/instrument-ui.ts';
	import { generateBlankTemplateCsv, generateInputCsv } from '../../platform/templates/generate-csv-template.ts';
	import { deadStockAdvancedAdapter } from '../../platform/adapters/dead-stock/advanced-adapter.ts';
	import { deadStockQuickAdapter } from '../../platform/adapters/dead-stock/quick-adapter.ts';
	import { analyzeDeadStock } from '../../tools/dead-stock-scanner/analyze.ts';
	import { deadStockResultToCsv } from '../../tools/dead-stock-scanner/export.ts';
	import { deadStockAdvancedContract } from '../../tools/dead-stock-scanner/modes/advanced/contract.ts';
	import { deadStockAdvancedSchema } from '../../tools/dead-stock-scanner/modes/advanced/schema.ts';
	import { deadStockAdvancedTemplate } from '../../tools/dead-stock-scanner/modes/advanced/template.ts';
	import { deadStockQuickContract } from '../../tools/dead-stock-scanner/modes/quick/contract.ts';
	import { deadStockQuickSchema } from '../../tools/dead-stock-scanner/modes/quick/schema.ts';
	import { deadStockQuickTemplate } from '../../tools/dead-stock-scanner/modes/quick/template.ts';
	import type { DeadStockAnalysis } from '../../tools/dead-stock-scanner/types.ts';
	import { validateDeadStockInput } from '../../tools/dead-stock-scanner/validate.ts';
	import { getDictionary, resolveMessage, type Locale } from '../../i18n/index.ts';

	const locale = ((window as unknown as { __WTLAB_LOCALE__?: Locale }).__WTLAB_LOCALE__ ?? 'en') as Locale;
	const rt = getDictionary(locale).results.deadStockScanner;
	const csvLabels = getDictionary(locale).common.csvIntake;
	const fieldLabels = Object.fromEntries(Object.entries(rt.fields).map(([id, field]) => [id, field.label]));

	initModeSwitcher();

	function fmt(value: number): string {
		return String(Math.round(value * 100) / 100);
	}
	const monthsWord = rt.labels.monthsUnit;

	// ---------- QUICK ----------

	const quickForm = document.querySelector<HTMLFormElement>('#quick-form');
	const quickManualIssues = document.getElementById('quick-manual-issues');
	const quickResults = document.getElementById('quick-results');
	const quickResultsBlock = document.getElementById('quick-results-block');
	let lastQuickAnalysis: DeadStockAnalysis | null = null;

	function renderQuickResult(analysis: DeadStockAnalysis) {
		if (!quickResults || !quickResultsBlock) return;
		lastQuickAnalysis = analysis;
		const item = analysis.items[0];
		quickResults.innerHTML = '';

		const cards = el('div', 'cards');

		const verdict = el('div', 'card');
		verdict.appendChild(el('h3', undefined, rt.headings.classification));
		verdict.appendChild(el('p', 'card-value', rt.classification[item.classification]));
		if (item.primaryWarningCode) verdict.appendChild(el('p', 'card-note', resolveMessage(locale, item.primaryWarningCode)));
		verdict.appendChild(el('p', 'card-note', resolveMessage(locale, item.recommendedActionCode)));
		cards.appendChild(verdict);

		const numbers = el('div', 'card');
		numbers.appendChild(el('h3', undefined, rt.headings.numbers));
		const dl = el('dl');
		dl.append(
			el('dt', undefined, rt.labels.coverage),
			el('dd', undefined, item.coverageMonths === undefined ? rt.labels.noConsumption : `${fmt(item.coverageMonths)} ${monthsWord}`),
			el('dt', undefined, rt.labels.dormancy),
			el('dd', undefined, rt.dormancyStatus[item.dormancyStatus]),
			el('dt', undefined, rt.labels.futureDemandSupport),
			el('dd', undefined, item.futureDemandSupport ? rt.labels.demandSupportsYes : rt.labels.demandSupportsNo),
			el('dt', undefined, rt.labels.excessQuantity),
			el('dd', undefined, fmt(item.excessQuantity)),
			el('dt', undefined, rt.labels.exposureValue),
			el('dd', undefined, item.exposureValue === undefined ? rt.labels.exposureUnknown : fmt(item.exposureValue))
		);
		numbers.appendChild(dl);
		cards.appendChild(numbers);

		const reasons = el('div', 'card');
		reasons.appendChild(el('h3', undefined, rt.headings.whyReasonCodes));
		const list = el('ul');
		// Reason codes are stable machine codes (Task 007) — never translated.
		for (const code of item.reasonCodes) list.appendChild(el('li', undefined, code));
		reasons.appendChild(list);
		reasons.appendChild(
			el(
				'p',
				'card-note',
				rt.labels.thresholdsNote
					.replace('{high}', String(analysis.thresholds.highCoverageMonths))
					.replace('{excess}', String(analysis.thresholds.excessCoverageMonths))
					.replace('{dormant}', String(analysis.thresholds.dormantMonths))
					.replace('{dead}', String(analysis.thresholds.deadMonths))
			)
		);
		cards.appendChild(reasons);

		quickResults.appendChild(cards);
		quickResultsBlock.hidden = false;
		quickResultsBlock.scrollIntoView({ block: 'nearest' });
	}

	function runQuick(confirmed: ConfirmedIntake) {
		const adapted = deadStockQuickAdapter(confirmed);
		if (!adapted.ok) {
			renderIssues(quickManualIssues, adapted.issues, locale, fieldLabels);
			return;
		}
		const validated = validateDeadStockInput(adapted.data);
		if (!validated.valid) {
			renderIssues(
				quickManualIssues,
				validated.errors.map((e) => ({ severity: 'error' as const, code: e.code, params: e.params, message: e.message })),
				locale,
				fieldLabels
			);
			return;
		}
		renderQuickResult(analyzeDeadStock(validated.data));
	}

	function quickFormRow(): Record<string, string> {
		const value = (name: string) => {
			const field = quickForm?.elements.namedItem(name);
			return field instanceof HTMLInputElement ? field.value : '';
		};
		return {
			item: value('item'),
			currentStock: value('currentStock'),
			recentMonthlyConsumption: value('recentMonthlyConsumption'),
			monthsSinceLastMovement: value('monthsSinceLastMovement'),
			futureDemand: value('futureDemand'),
			unitCost: value('unitCost'),
			thresholdMonths: value('thresholdMonths'),
		};
	}

	if (quickForm) {
		quickForm.addEventListener('submit', (event) => {
			event.preventDefault();
			const record: RawIntakeRecord = { values: quickFormRow(), unknown: {} };
			const result = validateRecords([record], deadStockQuickSchema);
			if (result.errorCount > 0) {
				renderIssues(quickManualIssues, result.issues.filter((issue) => issue.severity === 'error'), locale, fieldLabels);
				return;
			}
			renderIssues(quickManualIssues, result.issues.filter((issue) => issue.severity === 'warning'), locale, fieldLabels);
			const outcome = confirmIntake(deadStockQuickSchema, result);
			if (outcome.confirmed) runQuick(outcome.data);
		});
	}

	document.getElementById('quick-download-input')?.addEventListener('click', () => {
		download(deadStockQuickContract.exportProfile.inputFilename, 'text/csv', generateInputCsv(deadStockQuickTemplate, [quickFormRow()]));
	});
	document.getElementById('quick-download-template')?.addEventListener('click', () => {
		download('dead-stock-quick-template.csv', 'text/csv', generateBlankTemplateCsv(deadStockQuickTemplate));
	});
	document.getElementById('quick-download-result')?.addEventListener('click', () => {
		if (lastQuickAnalysis) {
			download(deadStockQuickContract.exportProfile.resultFilename, 'text/csv', deadStockResultToCsv(lastQuickAnalysis));
		}
	});
	setupCsvIntake('quick-intake', deadStockQuickSchema, runQuick, csvLabels, locale, fieldLabels);

	// ---------- ADVANCED ----------

	const ADV_FIELDS = [
		{ id: 'item' },
		{ id: 'currentStock' },
		{ id: 'recentMonthlyConsumption' },
		{ id: 'monthsSinceLastMovement' },
		{ id: 'futureDemand' },
		{ id: 'unitCost' },
		{ id: 'category' },
	];
	const advTable = setupRowTable('adv-body', ADV_FIELDS, getDictionary(locale).common.removeRow);
	const advManualIssues = document.getElementById('adv-manual-issues');
	const advResults = document.getElementById('adv-results');
	const advResultsBlock = document.getElementById('adv-results-block');
	let lastAdvAnalysis: DeadStockAnalysis | null = null;

	function renderAdvanced(analysis: DeadStockAnalysis) {
		if (!advResults || !advResultsBlock) return;
		lastAdvAnalysis = analysis;
		advResults.innerHTML = '';

		const summary = analysis.summary;
		const cards = el('div', 'cards');
		const addStat = (label: string, value: string, note?: string) => {
			const card = el('div', 'card');
			card.appendChild(el('h3', undefined, label));
			card.appendChild(el('p', 'card-value', value));
			if (note) card.appendChild(el('p', 'card-note', note));
			cards.appendChild(card);
		};
		addStat(
			rt.labels.items,
			String(summary.totalItems),
			`${rt.classification.healthy} ${summary.counts.healthy} · ${rt.classification['slow-moving']} ${summary.counts['slow-moving']} · ${rt.classification.dormant} ${summary.counts.dormant} · ${rt.classification['dead-stock']} ${summary.counts['dead-stock']} · ${rt.classification['excess-exposure']} ${summary.counts['excess-exposure']}`
		);
		addStat(rt.labels.totalExcessQuantity, fmt(summary.totalExcessQuantity));
		addStat(
			rt.labels.estimatedExposure,
			fmt(summary.totalExposureValue),
			summary.itemsWithoutUnitCost > 0 ? rt.labels.exposureLowerBound.replace('{count}', String(summary.itemsWithoutUnitCost)) : undefined
		);
		const summarySet = el('div', 'result-set');
		summarySet.appendChild(el('h3', undefined, rt.headings.portfolioSummary));
		summarySet.appendChild(cards);
		advResults.appendChild(summarySet);

		if (summary.topRiskItems.length > 0) {
			const risk = el('div', 'result-set');
			risk.appendChild(el('h3', undefined, rt.headings.topRiskItems));
			const list = el('ol');
			for (const name of summary.topRiskItems) {
				const item = analysis.items.find((candidate) => candidate.item === name);
				list.appendChild(el('li', undefined, item ? `${name} — ${rt.classification[item.classification]}${item.exposureValue !== undefined ? ` · ${fmt(item.exposureValue)}` : ''}` : name));
			}
			risk.appendChild(list);
			advResults.appendChild(risk);
		}

		const tableSet = el('div', 'result-set');
		tableSet.appendChild(el('h3', undefined, rt.headings.items));
		const wrap = el('div', 'table-wrap');
		const table = el('table');
		const thead = el('thead');
		const headRow = el('tr');
		const headers = [
			rt.fields.item.label,
			rt.headings.classification,
			rt.labels.coverage,
			rt.labels.dormancy,
			rt.labels.excessQuantity,
			rt.labels.exposureValue,
			rt.labels.priority,
			rt.labels.reasons,
		];
		for (const header of headers) {
			headRow.appendChild(el('th', undefined, header));
		}
		thead.appendChild(headRow);
		table.appendChild(thead);
		const tbody = el('tbody');
		for (const item of analysis.items) {
			const tr = el('tr');
			tr.append(
				el('td', undefined, item.item),
				el('td', item.priority === 'high' ? 'cell-high' : item.priority === 'medium' ? 'cell-medium' : undefined, rt.classification[item.classification]),
				el('td', undefined, item.coverageMonths === undefined ? 'n/a' : `${fmt(item.coverageMonths)} ${monthsWord}`),
				el('td', undefined, rt.dormancyStatus[item.dormancyStatus]),
				el('td', undefined, fmt(item.excessQuantity)),
				el('td', undefined, item.exposureValue === undefined ? rt.labels.exposureUnknown : fmt(item.exposureValue)),
				el('td', undefined, rt.priority[item.priority]),
				// Reason codes are stable machine codes (Task 007) — never translated.
				el('td', undefined, item.reasonCodes.join(', '))
			);
			tbody.appendChild(tr);
		}
		table.appendChild(tbody);
		wrap.appendChild(table);
		tableSet.appendChild(wrap);
		advResults.appendChild(tableSet);

		advResultsBlock.hidden = false;
		advResultsBlock.scrollIntoView({ block: 'nearest' });
	}

	function runAdvanced(confirmed: ConfirmedIntake) {
		const adapted = deadStockAdvancedAdapter(confirmed);
		if (!adapted.ok) {
			renderIssues(advManualIssues, adapted.issues, locale, fieldLabels);
			return;
		}
		const validated = validateDeadStockInput(adapted.data);
		if (!validated.valid) {
			renderIssues(
				advManualIssues,
				validated.errors.map((e) => ({ severity: 'error' as const, code: e.code, params: e.params, message: e.message })),
				locale,
				fieldLabels
			);
			return;
		}
		renderIssues(advManualIssues, [], locale, fieldLabels);
		renderAdvanced(analyzeDeadStock(validated.data));
	}

	function advLongRows(): Array<Record<string, string>> {
		return advTable.rows().map((values) => ({ ...values, note: '' }));
	}

	document.getElementById('adv-add-row')?.addEventListener('click', () => advTable.addRow());
	document.getElementById('adv-run')?.addEventListener('click', () => {
		const records: RawIntakeRecord[] = advLongRows().map((values) => ({ values, unknown: {} }));
		const result = validateRecords(records, deadStockAdvancedSchema);
		if (result.errorCount > 0) {
			renderIssues(advManualIssues, result.issues.filter((issue) => issue.severity === 'error'), locale, fieldLabels);
			return;
		}
		const outcome = confirmIntake(deadStockAdvancedSchema, result);
		if (outcome.confirmed) runAdvanced(outcome.data);
	});
	document.getElementById('adv-download-input')?.addEventListener('click', () => {
		download(deadStockAdvancedContract.exportProfile.inputFilename, 'text/csv', generateInputCsv(deadStockAdvancedTemplate, advLongRows()));
	});
	document.getElementById('adv-download-template')?.addEventListener('click', () => {
		download('dead-stock-advanced-template.csv', 'text/csv', generateBlankTemplateCsv(deadStockAdvancedTemplate));
	});
	document.getElementById('adv-download-result')?.addEventListener('click', () => {
		if (lastAdvAnalysis) {
			download(deadStockAdvancedContract.exportProfile.resultFilename, 'text/csv', deadStockResultToCsv(lastAdvAnalysis));
		}
	});
	setupCsvIntake('advanced-intake', deadStockAdvancedSchema, runAdvanced, csvLabels, locale, fieldLabels);
</script>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
	}

	:global(.cell-high) {
		color: var(--color-accent-strong);
		font-weight: 600;
	}

	:global(.cell-medium) {
		color: var(--color-accent);
	}
</style>
