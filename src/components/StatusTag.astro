---
// Status is always communicated with a text label (never color alone).
// Locale-safe: labels come from the shared dictionary, never hardcoded.
import { getDictionary, type Locale } from '../i18n';
import type { CatalogStatus, ImplementationState } from '../platform/catalog';

interface Props {
	status: CatalogStatus;
	implementationState: ImplementationState;
	enabled: boolean;
	locale?: Locale;
}

const { status, implementationState, enabled, locale = 'en' } = Astro.props;
const t = getDictionary(locale).common.statusTag;
---

<p class="status-tags">
	<span class:list={['tag', enabled && status === 'available' ? 'tag-live' : undefined]}>
		{t.status[status]}
	</span>
	<span class="tag">{t.implementationState[implementationState]}</span>
	{!enabled && <span class="tag tag-muted">{t.disabled}</span>}
</p>

<style>
	.status-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
		margin: 0;
	}

	.tag {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-secondary);
		border: var(--border-hairline);
		padding: 2px 8px;
	}

	.tag-live {
		color: var(--color-accent);
		border-color: var(--color-accent);
	}

	.tag-muted {
		color: var(--color-text-muted);
	}
</style>
