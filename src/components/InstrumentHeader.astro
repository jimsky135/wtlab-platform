---
// Shared instrument page header (Sprint 005 third-instance promotion;
// Sprint 005.5 made it locale-aware). Machine metadata (id, layer,
// version, status) comes from the catalog entry; presentation text
// (displayName/description/coreQuestion) comes from the i18n
// `instruments` dictionary keyed by entry.id — the catalog's own
// strings are fallback content only.
import { getDictionary, localizePath, type Locale } from '../i18n';
import type { InstrumentEntry } from '../platform/catalog';
import StatusTag from './StatusTag.astro';

interface Props {
	entry: InstrumentEntry;
	locale?: Locale;
	/** Optional secondary title (e.g. a localized brand subtitle). */
	subtitle?: string;
}

const { entry, locale = 'en', subtitle } = Astro.props;
const t = getDictionary(locale);
const text = t.instruments[entry.id] ?? entry;
---

<header class="instrument-header">
	<p class="kicker">{t.instrumentPlaceholder.kickerPrefix} · {entry.layer}</p>
	<h1>
		{text.displayName}
		{subtitle && <span class="subtitle">{subtitle}</span>}
	</h1>
	<StatusTag status={entry.status} implementationState={entry.implementationState} enabled={entry.enabled} locale={locale} />
	<dl class="meta">
		<dt>{t.common.versionLabel}</dt>
		<dd>{entry.version}</dd>
		<dt>{t.instrumentsPage.coreQuestionLabel}</dt>
		<dd>{text.coreQuestion}</dd>
		<dt>{t.instrumentPlaceholder.purposeLabel}</dt>
		<dd>{text.description}</dd>
	</dl>
	<nav class="instrument-nav" aria-label="Instrument">
		<a href={localizePath(locale, '/instruments')}>← {t.instrumentsPage.kicker}</a>
		<a href={localizePath(locale, '/command')}>{t.nav.items.today}</a>
	</nav>
</header>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-sm);
	}

	.subtitle {
		font-family: var(--font-body);
		font-style: normal;
		font-size: 1rem;
		color: var(--color-text-secondary);
	}

	.meta {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-xs) var(--space-md);
		margin: var(--space-md) 0 0;
	}

	.meta dt {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.meta dd {
		margin: 0;
		color: var(--color-text-primary);
	}

	.instrument-nav {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-md);
		margin-top: var(--space-md);
	}

	.instrument-nav a {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		text-decoration: none;
	}
</style>
