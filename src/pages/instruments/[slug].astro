---
// Registry-driven placeholder routes for instruments that are known in
// the architecture but not implemented yet. The implemented instrument
// (Water Level Checker) lives at its own confirmed route and is not
// generated here.
import StatusTag from '../../components/StatusTag.astro';
import PlatformShell from '../../layouts/PlatformShell.astro';
import { instruments } from '../../platform/instruments';

export function getStaticPaths() {
	return instruments
		.filter(
			(instrument) =>
				instrument.route.startsWith('/instruments/') && instrument.implementationState === 'placeholder'
		)
		.map((instrument) => ({ params: { slug: instrument.slug }, props: { instrument } }));
}

const { instrument } = Astro.props;
---

<PlatformShell title={`${instrument.displayName} · WTLab`} section="instruments">
	<p class="kicker">Instrument · {instrument.layer}</p>
	<h1>{instrument.displayName}</h1>
	<StatusTag
		status={instrument.status}
		implementationState={instrument.implementationState}
		enabled={instrument.enabled}
	/>

	<dl class="facts">
		<dt>Purpose</dt>
		<dd>{instrument.description}</dd>
		<dt>Core question</dt>
		<dd>{instrument.coreQuestion}</dd>
		<dt>Category</dt>
		<dd>{instrument.category}</dd>
		{instrument.prototypeRefs.length > 0 && (
			<>
				<dt>Related prototypes</dt>
				<dd>{instrument.prototypeRefs.join(', ')} (visual reference only, not part of this build)</dd>
			</>
		)}
	</dl>

	<p class="notice">
		This instrument is planned but not yet implemented. Nothing on this page performs a calculation.
	</p>

	<p class="back"><a href="/instruments">← Back to Instrument Library</a></p>
</PlatformShell>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
	}

	.facts {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-xs) var(--space-md);
		margin: var(--space-lg) 0 0;
		border-top: var(--border-hairline);
		padding-top: var(--space-lg);
	}

	.facts dt {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.facts dd {
		margin: 0;
		color: var(--color-text-primary);
	}

	.notice {
		margin: var(--space-lg) 0 0;
		border: var(--border-hairline);
		padding: var(--space-md);
		color: var(--color-text-secondary);
	}

	.back {
		margin: var(--space-lg) 0 0;
	}

	.back a {
		color: var(--color-accent);
	}
</style>
