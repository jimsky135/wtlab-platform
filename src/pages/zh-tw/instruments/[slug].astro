---
// Thin Traditional Chinese route wrapper — same shared view as English.
import InstrumentPlaceholderView from '../../../views/InstrumentPlaceholderView.astro';
import { instruments } from '../../../platform/instruments';

export function getStaticPaths() {
	return instruments
		.filter(
			(instrument) =>
				instrument.route.startsWith('/instruments/') && instrument.implementationState === 'placeholder'
		)
		.map((instrument) => ({ params: { slug: instrument.slug }, props: { instrument } }));
}

const { instrument } = Astro.props;
---

<InstrumentPlaceholderView instrument={instrument} locale="zh-TW" />
