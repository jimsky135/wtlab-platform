---
// Thin Traditional Chinese route wrapper — same shared view as English.
import WorkspacePlaceholderView from '../../../views/WorkspacePlaceholderView.astro';
import { workspaces } from '../../../platform/workspaces';

export function getStaticPaths() {
	return workspaces
		.filter(
			(workspace) =>
				workspace.route.startsWith('/workspace/') && workspace.implementationState === 'placeholder'
		)
		.map((workspace) => ({ params: { slug: workspace.slug }, props: { workspace } }));
}

const { workspace } = Astro.props;
---

<WorkspacePlaceholderView workspace={workspace} locale="zh-TW" />
