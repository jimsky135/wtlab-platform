		color: var(--color-text-muted);
	}

	.related ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-md);
	}

	.related a {
		color: var(--color-accent);
		text-decoration: none;
		border-bottom: 1px solid var(--color-accent);
		padding-bottom: 2px;
	}
</style>
