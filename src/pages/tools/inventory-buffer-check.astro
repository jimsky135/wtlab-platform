	.continuity-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: var(--space-sm);
		margin-bottom: var(--space-sm);
	}

	.continuity-actions button {
		background: var(--color-bg-raised);
		border: var(--border-hairline);
		color: var(--color-text-primary);
		font-family: var(--font-mono);
		font-size: 11px;
