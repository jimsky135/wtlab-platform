		padding: var(--space-xs) var(--space-md);
		cursor: pointer;
	}

	.continuity-actions button:disabled {
		color: var(--color-text-muted);
		cursor: not-allowed;
	}

	.continuity-hint {
		font-size: 0.85rem;
		color: var(--color-text-muted);
