---
// Water Level Checker — first fully integrated WTLab platform instrument.
// Availability gating stays with the execution registry; all display
// metadata comes from the platform catalog (no duplicated constants).
// The calculation core (validate.ts / calculate.ts) is untouched.
import StatusTag from '../../components/StatusTag.astro';
import PlatformShell from '../../layouts/PlatformShell.astro';
import { ALL_CAPABILITIES, CAPABILITY_LABELS, findById } from '../../platform/catalog';
import { instruments } from '../../platform/instruments';
import { platformRegistry } from '../../platform/registry';

const TOOL_ID = 'inventory-buffer-check';
const available = platformRegistry.isAvailable(TOOL_ID);
const entry = findById(instruments, TOOL_ID);

const relatedLinks = [
	{ label: 'Decision Priority Map', href: '/workspace/decision-priority' },
	{ label: 'Entity Workspace', href: '/workspace/entity' },
	{ label: 'Command Center', href: '/command' },
	{ label: 'Continuity', href: '/continuity' },
];
---

<PlatformShell title={`${entry?.displayName ?? 'Instrument'} · WTLab`} section="instruments">
	{available && entry ? (
		<article>
			<header class="tool-header">
				<p class="kicker">Instrument · {entry.layer}</p>
				<h1>
					{entry.displayName}
					<span class="subtitle">庫存水位檢查器</span>
				</h1>
				<StatusTag status={entry.status} implementationState={entry.implementationState} enabled={entry.enabled} />
				<dl class="tool-meta">
					<dt>Version</dt>
					<dd>{entry.version}</dd>
					<dt>Core question</dt>
					<dd>{entry.coreQuestion}</dd>
					<dt>Description</dt>
					<dd>{entry.description}</dd>
				</dl>
				<nav class="tool-nav" aria-label="Instrument">
					<a href="/instruments">← Instrument Library</a>
					<a href="/command">Command Center</a>
				</nav>
			</header>

			<section class="capabilities" aria-labelledby="capabilities-heading">
				<h2 id="capabilities-heading">Capabilities</h2>
				<ul>
					{ALL_CAPABILITIES.map((capability) => {
						const present = entry.capabilities.includes(capability);
						return (
							<li class:list={['capability', present ? 'present' : 'future']}>
								{CAPABILITY_LABELS[capability]}
								{!present && <span class="future-tag">Future</span>}
							</li>
						);
					})}
				</ul>
			</section>

			<form id="water-level-form">
				<fieldset>
					<legend>Inventory</legend>
					<div class="field">
						<label for="currentStock">Current Stock</label>
						<input id="currentStock" name="currentStock" type="text" inputmode="decimal" required />
					</div>
					<div class="field">
						<label for="inTransitQuantity">In-Transit Quantity <span class="optional-marker">(optional)</span></label>
						<input id="inTransitQuantity" name="inTransitQuantity" type="text" inputmode="decimal" />
					</div>
				</fieldset>

				<fieldset>
					<legend>Lead Time</legend>
					<div class="field-row">
						<div class="field">
							<label for="leadTime">Replenishment Lead Time</label>
							<input id="leadTime" name="leadTime" type="text" inputmode="decimal" required />
						</div>
						<div class="field field-unit">
							<label for="leadTimeUnit">Unit</label>
							<select id="leadTimeUnit" name="leadTimeUnit">
								<option value="month">month</option>
								<option value="day">day</option>
							</select>
						</div>
					</div>
					<div class="field-row">
						<div class="field">
							<label for="arrivalTime">Expected Arrival Time <span class="optional-marker">(optional)</span></label>
							<input id="arrivalTime" name="arrivalTime" type="text" inputmode="decimal" />
						</div>
						<div class="field field-unit">
							<label for="arrivalTimeUnit">Unit</label>
							<select id="arrivalTimeUnit" name="arrivalTimeUnit">
								<option value="month">month</option>
								<option value="day">day</option>
							</select>
						</div>
					</div>
				</fieldset>

				<fieldset>
					<legend>Safety Buffer</legend>
					<div class="field-row">
						<div class="field">
							<label for="safetyBuffer">Safety Buffer</label>
							<input id="safetyBuffer" name="safetyBuffer" type="text" inputmode="decimal" required />
						</div>
						<div class="field field-unit">
							<label for="safetyBufferUnit">Unit</label>
							<select id="safetyBufferUnit" name="safetyBufferUnit">
								<option value="month">month</option>
								<option value="day">day</option>
							</select>
						</div>
					</div>
				</fieldset>

				<fieldset>
					<legend>Demand</legend>
					<div class="field">
						<label for="monthlyConsumption">Monthly Consumption</label>
						<input id="monthlyConsumption" name="monthlyConsumption" type="text" inputmode="decimal" required />
					</div>
				</fieldset>

				<button type="submit">Check</button>
			</form>

			<section id="validation-panel" class="validation-panel" aria-live="polite" hidden>
				<h2>Validation</h2>
				<p class="validation-explain">
					The calculation did not run. Each item below names the field and the rule it failed — correct
					the inputs and check again.
				</p>
				<h3>Errors</h3>
				<ul id="validation-errors"></ul>
			</section>

			<section id="results" class="results" aria-live="polite" hidden>
				<h2>Results</h2>
				<div class="cards">
					<div class="card">
						<h3>Inventory Status</h3>
						<p class="card-value" id="r-risk-label"></p>
						<p class="card-note" id="r-risk-desc"></p>
					</div>
					<div class="card">
						<h3>Coverage</h3>
						<dl>
							<dt>Current coverage</dt>
							<dd id="r-coverage-current"></dd>
							<dt>Total coverage (incl. in-transit)</dt>
							<dd id="r-coverage-total"></dd>
						</dl>
					</div>
					<div class="card">
						<h3>Recommendation</h3>
						<dl>
							<dt>Minimum safety stock</dt>
							<dd id="r-min-stock"></dd>
							<dt>Reorder point</dt>
							<dd id="r-reorder"></dd>
						</dl>
					</div>
					<div class="card">
						<h3>Evidence &amp; Notes</h3>
						<dl>
							<dt>Arrival risk</dt>
							<dd id="r-arrival"></dd>
						</dl>
						<ul class="notes" id="r-notes"></ul>
					</div>
				</div>
			</section>

			<section class="continuity" aria-labelledby="continuity-heading">
				<h2 id="continuity-heading">Continuity</h2>
				<div class="continuity-actions">
					<button type="button" id="export-csv" disabled>Export CSV</button>
					<button type="button" id="export-json" disabled>Export JSON</button>
					<span class="continuity-hint" id="export-hint">Run a check to enable export.</span>
				</div>
				<div class="continuity-actions planned-actions">
					<button type="button" disabled>Prepare AI Context</button>
					<span class="planned-tag">Planned</span>
					<button type="button" disabled>Email Copy</button>
					<span class="planned-tag">Planned</span>
					<button type="button" disabled>Save Session</button>
					<span class="planned-tag">Planned</span>
				</div>
			</section>

			<section class="related" aria-labelledby="related-heading">
				<h2 id="related-heading">Related</h2>
				<ul>
					{relatedLinks.map((link) => (
						<li><a href={link.href}>{link.label}</a></li>
					))}
				</ul>
			</section>
		</article>
	) : (
		<article>
			<p class="kicker">WTLab</p>
			<h1>This tool is not currently available.</h1>
			<p><a href="/instruments">← Back to Instrument Library</a></p>
		</article>
	)}
</PlatformShell>

<script>
	import { calculateInventoryBuffer } from '../../tools/inventory-buffer-check/calculate.ts';
	import { outputToCsv, outputToJson } from '../../tools/inventory-buffer-check/export.ts';
	import type {
		ArrivalRisk,
		InventoryBufferOutput,
		InventoryBufferRawInput,
		RiskStatus,
		TimeUnit,
	} from '../../tools/inventory-buffer-check/types.ts';
	import { validateInventoryBufferInput } from '../../tools/inventory-buffer-check/validate.ts';

	const form = document.querySelector<HTMLFormElement>('#water-level-form');
	const validationPanel = document.querySelector<HTMLElement>('#validation-panel');
	const errorsList = document.querySelector<HTMLElement>('#validation-errors');
	const resultsEl = document.querySelector<HTMLElement>('#results');
	const exportCsvBtn = document.querySelector<HTMLButtonElement>('#export-csv');
	const exportJsonBtn = document.querySelector<HTMLButtonElement>('#export-json');
	const exportHint = document.querySelector<HTMLElement>('#export-hint');

	if (form && validationPanel && errorsList && resultsEl && exportCsvBtn && exportJsonBtn && exportHint) {
		const ARRIVAL_RISK_TEXT: Record<ArrivalRisk, string> = {
			'possible-shortage': 'Possible shortage before arrival',
			'can-cover-until-arrival': 'Current stock can cover until arrival',
			'arrival-time-not-provided': 'Arrival time not provided',
		};

		const RISK_STATUS_TEXT: Record<RiskStatus, { label: string; description: string }> = {
			safe: {
				label: 'Safe',
				description: 'Inventory covers replenishment lead time and safety buffer.',
			},
			caution: {
				label: 'Caution',
				description: 'Inventory has entered the safety buffer zone. Confirm replenishment or arrival timing.',
			},
			'high-risk': {
				label: 'High Risk',
				description: 'Inventory coverage is shorter than the normal replenishment lead time.',
			},
		};

		let lastOutput: InventoryBufferOutput | null = null;

		function fieldValue(name: string): string {
			const field = form!.elements.namedItem(name);
			return field instanceof HTMLInputElement || field instanceof HTMLSelectElement ? field.value : '';
		}

		function optionalFieldValue(name: string): string | undefined {
			const value = fieldValue(name);
			return value.trim() === '' ? undefined : value;
		}

		function formatMonths(value: number): string {
			return `${value.toFixed(1)} months`;
		}

		function formatQuantity(value: number): string {
			return String(Math.round(value * 100) / 100);
		}

		function setText(id: string, text: string) {
			const el = document.getElementById(id);
			if (el) el.textContent = text;
		}

		function renderErrors(errors: string[]) {
			resultsEl!.hidden = true;
			lastOutput = null;
			exportCsvBtn!.disabled = true;
			exportJsonBtn!.disabled = true;
			exportHint!.hidden = false;
			errorsList!.innerHTML = '';
			for (const message of errors) {
				const item = document.createElement('li');
				item.textContent = message;
				errorsList!.appendChild(item);
			}
			validationPanel!.hidden = false;
		}

		function renderResults(output: InventoryBufferOutput) {
			validationPanel!.hidden = true;
			lastOutput = output;
			exportCsvBtn!.disabled = false;
			exportJsonBtn!.disabled = false;
			exportHint!.hidden = true;

			const risk = RISK_STATUS_TEXT[output.riskStatus];
			setText('r-risk-label', risk.label);
			setText('r-risk-desc', risk.description);
			setText('r-coverage-current', formatMonths(output.currentCoverageMonths));
			setText(
				'r-coverage-total',
				output.totalCoverageMonths === undefined ? 'Not provided' : formatMonths(output.totalCoverageMonths)
			);
			setText('r-min-stock', formatQuantity(output.minimumSafetyStock));
			setText('r-reorder', formatQuantity(output.reorderPoint));
			setText('r-arrival', ARRIVAL_RISK_TEXT[output.arrivalRisk]);

			const notes = document.getElementById('r-notes');
			if (notes) {
				notes.innerHTML = '';
				const messages: string[] = [];
				if (output.totalCoverageMonths === undefined) {
					messages.push('In-transit quantity not provided — total coverage was not calculated.');
				}
				if (output.arrivalRisk === 'arrival-time-not-provided') {
					messages.push('Expected arrival time not provided — arrival risk was not assessed.');
				}
				for (const message of messages) {
					const item = document.createElement('li');
					item.textContent = message;
					notes.appendChild(item);
				}
			}

			resultsEl!.hidden = false;
		}

		function download(filename: string, mime: string, content: string) {
			const blob = new Blob([content], { type: mime });
			const url = URL.createObjectURL(blob);
			const link = document.createElement('a');
			link.href = url;
			link.download = filename;
			link.click();
			URL.revokeObjectURL(url);
		}

		exportCsvBtn.addEventListener('click', () => {
			if (lastOutput) download('water-level-checker.csv', 'text/csv', outputToCsv(lastOutput));
		});

		exportJsonBtn.addEventListener('click', () => {
			if (lastOutput) download('water-level-checker.json', 'application/json', outputToJson(lastOutput));
		});

		form.addEventListener('submit', (event) => {
			event.preventDefault();

			const raw: InventoryBufferRawInput = {
				currentStock: fieldValue('currentStock'),
				monthlyConsumption: fieldValue('monthlyConsumption'),
				leadTime: fieldValue('leadTime'),
				leadTimeUnit: fieldValue('leadTimeUnit') as TimeUnit,
				safetyBuffer: fieldValue('safetyBuffer'),
				safetyBufferUnit: fieldValue('safetyBufferUnit') as TimeUnit,
				inTransitQuantity: optionalFieldValue('inTransitQuantity'),
				arrivalTime: optionalFieldValue('arrivalTime'),
				arrivalTimeUnit: fieldValue('arrivalTimeUnit') as TimeUnit,
			};

			const result = validateInventoryBufferInput(raw);

			if (!result.valid) {
				renderErrors(result.errors);
				return;
			}

			renderResults(calculateInventoryBuffer(result.data));
		});
	}
</script>

<style>
	.kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--space-sm);
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 var(--space-sm);
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-sm);
	}

	.subtitle {
		font-family: var(--font-body);
		font-style: normal;
		font-size: 1rem;
		color: var(--color-text-secondary);
	}

	.tool-meta {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-xs) var(--space-md);
		margin: var(--space-md) 0 0;
	}

	.tool-meta dt {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.tool-meta dd {
		margin: 0;
		color: var(--color-text-primary);
	}

	.tool-nav {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-md);
		margin-top: var(--space-md);
	}

	.tool-nav a {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		text-decoration: none;
	}

	section {
		border-top: var(--border-hairline);
		margin-top: var(--space-lg);
		padding-top: var(--space-lg);
	}

	h2 {
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-md);
	}

	.capabilities ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
	}

	.capability {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		border: var(--border-hairline);
		padding: 4px 10px;
		display: flex;
		align-items: center;
		gap: var(--space-xs);
	}

	.capability.present {
		color: var(--color-accent);
		border-color: var(--color-accent);
	}

	.capability.future {
		color: var(--color-text-muted);
	}

	.future-tag {
		font-size: 9px;
		color: var(--color-text-muted);
		border: var(--border-hairline);
		padding: 1px 6px;
	}

	form {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		border-top: var(--border-hairline);
		margin-top: var(--space-lg);
		padding-top: var(--space-lg);
	}

	fieldset {
		border: var(--border-hairline);
		padding: var(--space-md);
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		margin: 0;
	}

	legend {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-accent);
		padding: 0 var(--space-xs);
	}

	.field {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		flex: 1;
	}

	.field-row {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-md);
		align-items: flex-end;
	}

	.field-unit {
		flex: 0 0 8rem;
	}

	label {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-secondary);
	}

	.optional-marker {
		text-transform: none;
		letter-spacing: normal;
		color: var(--color-text-muted);
	}

	input,
	select {
		background: var(--color-bg-raised);
		border: var(--border-hairline);
		color: var(--color-text-primary);
		font-family: var(--font-body);
		font-size: 1rem;
		padding: var(--space-sm);
	}

	button[type='submit'] {
		align-self: flex-start;
		background: var(--color-accent);
		color: var(--color-bg);
		border: none;
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		padding: var(--space-sm) var(--space-lg);
		cursor: pointer;
	}

	.validation-panel {
		border: var(--border-hairline);
		padding: var(--space-md);
	}

	.validation-explain {
		color: var(--color-text-secondary);
		margin: 0 0 var(--space-sm);
	}

	.validation-panel h3 {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
		margin: 0 0 var(--space-xs);
	}

	.validation-panel ul {
		margin: 0;
		padding-left: 1.2em;
		color: var(--color-text-primary);
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: var(--space-sm);
	}

	.card {
		border: var(--border-hairline);
		padding: var(--space-md);
	}

	.card h3 {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: var(--tracking-kicker);
		text-transform: uppercase;
		color: var(--color-text-tertiary);
		margin: 0 0 var(--space-sm);
	}

	.card-value {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.8rem;
		color: var(--color-accent);
		margin: 0 0 var(--space-xs);
	}

	.card-note {
		color: var(--color-text-secondary);
		margin: 0;
		font-size: 0.95rem;
	}

	.card dl {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-xs);
		margin: 0;
	}

	.card dt {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-tertiary);
	}

	.card dd {
		margin: 0 0 var(--space-xs);
